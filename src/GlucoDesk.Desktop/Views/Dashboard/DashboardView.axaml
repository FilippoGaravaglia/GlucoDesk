<UserControl
    x:Class="GlucoDesk.Desktop.Views.Dashboard.DashboardView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:GlucoDesk.Desktop.Views.Dashboard.Controls"
             xmlns:statsControls="clr-namespace:GlucoDesk.Desktop.Controls.Statistics"
             xmlns:converters="clr-namespace:GlucoDesk.Desktop.Converters">
  <UserControl.Resources>
    <converters:WidthBelowThresholdConverter x:Key="WidthBelowThresholdConverter" />
    <converters:WidthAtLeastThresholdConverter x:Key="WidthAtLeastThresholdConverter" />
  </UserControl.Resources>


  <Border Classes="page-shell">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <Grid RowDefinitions="Auto,*"
            Margin="30"
            RowSpacing="26"
            MaxWidth="1540"
            HorizontalAlignment="Stretch">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="24">
          <StackPanel Spacing="8">
            <TextBlock Text="GlucoDesk"
                       Classes="page-title" />

            <TextBlock Text="{DynamicResource DashboardSubtitle}"
                       Classes="secondary"
                       FontSize="16" />
          </StackPanel>

          <Border MinWidth="260" Grid.Column="1"
                  Classes="badge-accent"
                  VerticalAlignment="Top">
            <TextBlock Text="{DynamicResource DashboardPrivateLocalFirstCompanion}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}" />
          </Border>
        </Grid>

        <StackPanel Grid.Row="1"
                    Spacing="22">

          <Border x:Name="CurrentGlucoseHeroCard"
                  Classes="hero-card">
            <Grid>
              <Grid ColumnDefinitions="1.15*,0.85*"
                    ColumnSpacing="34"
                    IsVisible="{Binding #CurrentGlucoseHeroCard.Bounds.Width, Converter={StaticResource WidthAtLeastThresholdConverter}, ConverterParameter=1020}">
                <StackPanel Grid.Column="0"
                            Spacing="20">
                  <StackPanel Spacing="10">
                    <TextBlock Text="{DynamicResource DashboardCurrentGlucose}"
                               Classes="eyebrow" />

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="18"
                          VerticalAlignment="Center">
                      <TextBlock Text="{Binding LatestValueText}"
                                 Classes="hero-value" />

                      <StackPanel Grid.Column="1"
                                  Spacing="8"
                                  VerticalAlignment="Center">
                        <Border Classes="status-pill-success"
                                HorizontalAlignment="Left">
                          <TextBlock Text="{Binding StatusText}"
                                     FontSize="13"
                                     FontWeight="SemiBold"
                                     Foreground="{StaticResource GlucoDesk.Brush.Success}" />
                        </Border>

                        <TextBlock Text="{Binding TargetRangeText}"
                                   Classes="secondary"
                                   FontSize="13" />
                      </StackPanel>
                    </Grid>
                  </StackPanel>

                  <WrapPanel Orientation="Horizontal"
                             VerticalAlignment="Center">
                    <TextBlock Text="{Binding TrendText}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GlucoDesk.Brush.TextPrimary}" />
                  </WrapPanel>
                </StackPanel>

                <Border MinWidth="260"
                        Grid.Column="1"
                        BorderThickness="1,0,0,0"
                        BorderBrush="{StaticResource GlucoDesk.Brush.BorderSoft}"
                        Padding="28,0,0,0"
                        VerticalAlignment="Center">
                  <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="16">
                      <StackPanel Spacing="5">
                        <TextBlock Text="{DynamicResource DashboardProviderConnected}"
                                   Classes="section-title" />

                        <TextBlock Text="{Binding DataSourceStatusText}"
                                   Classes="secondary"
                                   FontSize="13"
                                   TextWrapping="Wrap" />
                      </StackPanel>

                      <Button Grid.Column="1"
                              Content="{DynamicResource DashboardRefresh}"
                              Command="{Binding RefreshCommand}"
                              VerticalAlignment="Top" />
                    </Grid>

                    <Border Height="1"
                            Background="{StaticResource GlucoDesk.Brush.BorderSoft}" />

                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="18">
                      <StackPanel Spacing="4">
                        <TextBlock Text="{DynamicResource DashboardUpdated}"
                                   Classes="metric-label" />

                        <TextBlock Text="{Binding LastUpdatedText}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource GlucoDesk.Brush.TextPrimary}" />
                      </StackPanel>

                      <Border MinWidth="260"
                              Grid.Column="1"
                              Classes="badge"
                              VerticalAlignment="Top">
                        <TextBlock Text="{Binding FreshnessText}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource GlucoDesk.Brush.TextSecondary}" />
                      </Border>
                    </Grid>
                  </StackPanel>
                </Border>
              </Grid>

              <StackPanel Spacing="22"
                          IsVisible="{Binding #CurrentGlucoseHeroCard.Bounds.Width, Converter={StaticResource WidthBelowThresholdConverter}, ConverterParameter=1020}">
                <StackPanel Spacing="12">
                  <TextBlock Text="{DynamicResource DashboardCurrentGlucose}"
                             Classes="eyebrow" />

                  <WrapPanel Orientation="Horizontal"
                             VerticalAlignment="Center">
                    <TextBlock Text="{Binding LatestValueText}"
                               Classes="hero-value"
                               Margin="0,0,22,0" />

                    <StackPanel Spacing="8"
                                VerticalAlignment="Center"
                                MinWidth="160">
                      <Border Classes="status-pill-success"
                              HorizontalAlignment="Left">
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource GlucoDesk.Brush.Success}" />
                      </Border>

                      <TextBlock Text="{Binding TrendText}"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource GlucoDesk.Brush.TextPrimary}" />
                    </StackPanel>
                  </WrapPanel>
                </StackPanel>

                <Border Height="1"
                        Background="{StaticResource GlucoDesk.Brush.BorderSoft}" />

                <StackPanel Spacing="14">
                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="16">
                    <StackPanel Spacing="5">
                      <TextBlock Text="{DynamicResource DashboardProviderConnected}"
                                 Classes="section-title" />

                      <TextBlock Text="{Binding DataSourceStatusText}"
                                 Classes="secondary"
                                 FontSize="13"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="{DynamicResource DashboardRefresh}"
                            Command="{Binding RefreshCommand}"
                            VerticalAlignment="Top" />
                  </Grid>

                  <WrapPanel Orientation="Horizontal">
                    <StackPanel Spacing="4"
                                Margin="0,0,18,0">
                      <TextBlock Text="{DynamicResource DashboardUpdated}"
                                 Classes="metric-label" />

                      <TextBlock Text="{Binding LastUpdatedText}"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource GlucoDesk.Brush.TextPrimary}" />
                    </StackPanel>

                    <Border Classes="badge"
                            VerticalAlignment="Top">
                      <TextBlock Text="{Binding FreshnessText}"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource GlucoDesk.Brush.TextSecondary}" />
                    </Border>
                  </WrapPanel>
                </StackPanel>
              </StackPanel>
            </Grid>
          </Border>

          <Border Classes="surface-card"
                  Padding="20"
                  IsVisible="{Binding IsGlucoseAlertBannerVisible}">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="18"
                  VerticalAlignment="Center">
              <Border Grid.Column="0"
                      Classes="badge-accent"
                      VerticalAlignment="Top">
                <TextBlock Text="{Binding GlucoseAlertBadgeText}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}" />
              </Border>

              <StackPanel Grid.Column="1"
                          Spacing="5">
                <TextBlock Text="{Binding GlucoseAlertTitle}"
                           Classes="section-title" />

                <TextBlock Text="{Binding GlucoseAlertMessage}"
                           Classes="secondary"
                           FontSize="13"
                           TextWrapping="Wrap" />

                <TextBlock Text="{Binding GlucoseAlertActionText}"
                           Classes="muted"
                           FontSize="12"
                           TextWrapping="Wrap" />
              </StackPanel>

              <StackPanel Grid.Column="2"
                          Orientation="Horizontal"
                          Spacing="10"
                          VerticalAlignment="Center">
                <Button Content="{DynamicResource DashboardSnooze}"
                        Command="{Binding SnoozeGlucoseAlertBannerCommand}" />

                <Button Content="{DynamicResource DashboardDismiss}"
                        Command="{Binding DismissGlucoseAlertBannerCommand}" />
              </StackPanel>
            </Grid>
          </Border>

          <Border Classes="chart-card">
            <StackPanel Spacing="18">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="18">
                <StackPanel Spacing="6">
                  <TextBlock Text="{DynamicResource DashboardRecentTrend}"
                             Classes="section-title" />

                  <TextBlock Text="{Binding ChartSummaryText}"
                             Classes="secondary"
                             FontSize="13" />

                  <TextBlock Text="{Binding AmbientGlucoseSummaryText}"
                             Classes="secondary"
                             FontSize="13"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Spacing="10"
                            HorizontalAlignment="Right">

                  <Border Classes="segmented-control"
                          HorizontalAlignment="Right">
                    <WrapPanel Orientation="Horizontal"
                               HorizontalAlignment="Right">
                      <Button Content="3H"
                              Command="{Binding SelectThreeHourChartWindowCommand}"
                              Classes="segment-button"
                              Classes.accent="{Binding IsThreeHourChartWindowSelected}"
                              MinWidth="48"
                              Padding="12,8"
                              Margin="0,0,6,0" />

                      <Button Content="6H"
                              Command="{Binding SelectSixHourChartWindowCommand}"
                              Classes="segment-button"
                              Classes.accent="{Binding IsSixHourChartWindowSelected}"
                              MinWidth="48"
                              Padding="12,8"
                              Margin="0,0,6,0" />

                      <Button Content="12H"
                              Command="{Binding SelectTwelveHourChartWindowCommand}"
                              Classes="segment-button"
                              Classes.accent="{Binding IsTwelveHourChartWindowSelected}"
                              MinWidth="54"
                              Padding="12,8"
                              Margin="0,0,6,0" />

                      <Button Content="24H"
                              Command="{Binding ShowTwentyFourHourChartWindowCommand}"
                              Classes="segment-button"
                              Classes.accent="{Binding IsTwentyFourHourChartWindowSelected}"
                              MinWidth="54"
                              Padding="12,8" />
                    </WrapPanel>
                  </Border>

                  <Border Classes="badge"
                          HorizontalAlignment="Right">
                    <TextBlock Text="{Binding TargetRangeText}"
                               Classes="muted"
                               FontSize="12"
                               TextAlignment="Right" />
                  </Border>
                </StackPanel>
              </Grid>

              <Border Classes="chart-shell"
                      Height="360"
                      Padding="12">
                <controls:GlucoseTrendChart
                    Points="{Binding ChartPoints}"
                    TargetLowMgDl="{Binding TargetLowMgDl}"
                    TargetHighMgDl="{Binding TargetHighMgDl}"
                    WindowHours="{Binding SelectedChartWindowHours}"
                    MaxVisibleMgDl="{Binding ChartMaximumMgDl}"
                    DisplayUnit="{Binding PreferredUnit}" />
              </Border>
            </StackPanel>
          </Border>

          <Border Classes="surface-card"
                  Padding="24">
            <StackPanel Spacing="22">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="18">
                <StackPanel Spacing="4">
                  <TextBlock Text="{DynamicResource DashboardGlucoseInsights}"
                             Classes="section-title" />

                  <TextBlock Text="{Binding StatisticsStatusText}"
                             TextWrapping="Wrap"
                             Classes="secondary"
                             FontSize="13" />

                  <TextBlock Text="{Binding StatisticsHistoryAvailabilityText}"
                             TextWrapping="Wrap"
                             Classes="muted"
                             FontSize="12" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Spacing="10"
                            HorizontalAlignment="Right">

                  <Border Classes="segmented-control"
                          HorizontalAlignment="Right">
                    <WrapPanel Orientation="Horizontal"
                               HorizontalAlignment="Right">
                      <Button Content="24H"
                              Command="{Binding SelectTwentyFourHourStatisticsWindowCommand}"
                              Classes="segment-button"
                              Classes.accent="{Binding IsTwentyFourHourStatisticsWindowSelected}"
                              MinWidth="50"
                              Padding="12,8"
                              Margin="0,0,6,0" />

                      <Button Content="3D"
                              Command="{Binding SelectThreeDayStatisticsWindowCommand}"
                              Classes="segment-button"
                              Classes.accent="{Binding IsThreeDayStatisticsWindowSelected}"
                              MinWidth="48"
                              Padding="12,8"
                              Margin="0,0,6,0" />

                      <Button Content="7D"
                              Command="{Binding SelectSevenDayStatisticsWindowCommand}"
                              Classes="segment-button"
                              Classes.accent="{Binding IsSevenDayStatisticsWindowSelected}"
                              MinWidth="48"
                              Padding="12,8"
                              Margin="0,0,6,0" />

                      <Button Content="14D"
                              Command="{Binding SelectFourteenDayStatisticsWindowCommand}"
                              Classes="segment-button"
                              Classes.accent="{Binding IsFourteenDayStatisticsWindowSelected}"
                              MinWidth="54"
                              Padding="12,8"
                              Margin="0,0,6,0" />

                      <Button Content="30D"
                              Command="{Binding SelectThirtyDayStatisticsWindowCommand}"
                              Classes="segment-button"
                              Classes.accent="{Binding IsThirtyDayStatisticsWindowSelected}"
                              MinWidth="54"
                              Padding="12,8"
                              Margin="0,0,6,0" />

                      <Button Content="90D"
                              Command="{Binding SelectNinetyDayStatisticsWindowCommand}"
                              Classes="segment-button"
                              Classes.accent="{Binding IsNinetyDayStatisticsWindowSelected}"
                              MinWidth="54"
                              Padding="12,8" />
                    </WrapPanel>
                  </Border>

                  <Border Classes="badge-accent"
                          HorizontalAlignment="Right">
                    <TextBlock Text="{Binding StatisticsWindowStatusText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}" />
                  </Border>
                </StackPanel>
              </Grid>

              <Grid ColumnDefinitions="1.1*,0.9*"
                    ColumnSpacing="28"
                    IsVisible="{Binding IsStatisticsCardsVisible}">

                <Border Grid.Column="0"
                        Padding="22"
                        CornerRadius="24"
                        BorderThickness="1"
                        BorderBrush="#86EFAC"
                        Background="{StaticResource GlucoDesk.Brush.SuccessPale}"
                        HorizontalAlignment="Stretch">
                  <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Spacing="4">
                        <TextBlock Text="{DynamicResource DashboardTimeInRange}"
                                   Classes="metric-label" />

                        <TextBlock Text="{Binding StatisticsTimeInRangeText}"
                                   Classes="insight-value" />
                      </StackPanel>

                      <Border MinWidth="260" Grid.Column="1"
                              Classes="badge-success"
                              VerticalAlignment="Top">
                        <TextBlock Text="Target"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource GlucoDesk.Brush.Success}" />
                      </Border>
                    </Grid>

                    <ProgressBar Classes="insight-progress-success"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding StatisticsTimeInRangePercentValue}" />

                    <TextBlock Text="{Binding StatisticsTimeInRangeInsightText}"
                               Classes="insight-copy"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Grid Grid.Column="1"
                      RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="18">

                  <Grid Grid.Row="0"
                        ColumnDefinitions="*,Auto"
                        ColumnSpacing="14">
                    <StackPanel Spacing="4">
                      <TextBlock Text="{DynamicResource DashboardAverageGlucose}"
                                 Classes="metric-label" />

                      <TextBlock Text="{Binding StatisticsAverageGlucoseText}"
                                 Classes="metric-value" />

                      <TextBlock Text="{Binding StatisticsAverageInsightText}"
                                 Classes="secondary"
                                 FontSize="13"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </Grid>

                  <Border Grid.Row="1"
                          Height="1"
                          Background="{StaticResource GlucoDesk.Brush.BorderSoft}" />

                                    <Grid Grid.Row="2"
                        RowDefinitions="Auto,Auto,Auto"
                        RowSpacing="10"
                        Margin="0,16,0,0">
                    <Grid ColumnDefinitions="*,24,*">
                      <Grid Grid.Column="0"
                            RowDefinitions="Auto,Auto"
                            RowSpacing="6">
                        <TextBlock Text="{DynamicResource DashboardBelowRange}"
                                   Classes="metric-label" />

                        <TextBlock Grid.Row="1"
                                   Text="{Binding StatisticsBelowRangeText}"
                                   Classes="metric-value" />
                      </Grid>

                      <Grid Grid.Column="2"
                            RowDefinitions="Auto,Auto"
                            RowSpacing="6">
                        <TextBlock Text="{DynamicResource DashboardAboveRange}"
                                   Classes="metric-label" />

                        <TextBlock Grid.Row="1"
                                   Text="{Binding StatisticsAboveRangeText}"
                                   Classes="metric-value" />
                      </Grid>
                    </Grid>

                    <statsControls:GlucoseRangeBarsControl
                        Grid.Row="1"
                        HorizontalAlignment="Stretch"
                        BelowPercent="{Binding StatisticsBelowRangePercentValue}"
                        AbovePercent="{Binding StatisticsAboveRangePercentValue}" />

                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,24,*">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding StatisticsBelowRangeInsightText}"
                                 Classes="secondary"
                                 FontSize="13"
                                 MaxWidth="170"
                                 TextWrapping="Wrap" />

                      <TextBlock Grid.Column="2"
                                 Text="{Binding StatisticsAboveRangeInsightText}"
                                 Classes="secondary"
                                 FontSize="13"
                                 MaxWidth="170"
                                 TextWrapping="Wrap" />
                    </Grid>
                  </Grid>
                </Grid>
              </Grid>

              <Border Classes="insight-empty-state"
                      IsVisible="{Binding IsStatisticsHistoryInsufficient}">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="18">
                  <Border Classes="empty-state-icon"
                          VerticalAlignment="Top">
                    <TextBlock Text="↗"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}" />
                  </Border>

                  <StackPanel Grid.Column="1"
                              Spacing="8">
                    <TextBlock Text="{Binding StatisticsInsufficientHistoryTitle}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GlucoDesk.Brush.TextPrimary}" />

                    <TextBlock Text="{Binding StatisticsInsufficientHistoryMessage}"
                               TextWrapping="Wrap"
                               Classes="secondary"
                               FontSize="14" />

                    <TextBlock Text="{DynamicResource DashboardFreshSetupHistoryHint}"
                               TextWrapping="Wrap"
                               Classes="muted"
                               FontSize="12" />
                  </StackPanel>
                </Grid>
              </Border>
            </StackPanel>
          </Border>

          <Border Classes="notice-card-danger"
                  IsVisible="{Binding HasError}">
            <StackPanel Spacing="6">
              <TextBlock Text="Dashboard error"
                         Classes="section-title"
                         Foreground="{StaticResource GlucoDesk.Brush.Danger}" />

              <TextBlock Text="{Binding ErrorMessage}"
                         TextWrapping="Wrap"
                         Foreground="{StaticResource GlucoDesk.Brush.TextSecondary}" />
            </StackPanel>
          </Border>

          <Border Classes="notice-card-warning"
                  IsVisible="{Binding IsMockProviderActive}">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="14">
              <Border Classes="notice-dot-warning"
                      VerticalAlignment="Top" />

              <StackPanel Grid.Column="1"
                          Spacing="5">
                <TextBlock Text="Demo mode active"
                           Classes="section-title"
                           Foreground="{StaticResource GlucoDesk.Brush.Warning}" />

                <TextBlock Text="Mock provider is currently powering the dashboard. Configure and select Dexcom or Nightscout in Settings to use real provider data."
                           TextWrapping="Wrap"
                           Foreground="{StaticResource GlucoDesk.Brush.TextSecondary}" />
              </StackPanel>
            </Grid>
          </Border>

          <Border Padding="18"
                  CornerRadius="22"
                  BorderThickness="1"
                  BorderBrush="{StaticResource GlucoDesk.Brush.BorderSoft}"
                  Background="{StaticResource GlucoDesk.Brush.AccentPale}"
                  Margin="0,0,0,24">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="14">
              <Border Width="10"
                      Height="10"
                      CornerRadius="999"
                      Background="{StaticResource GlucoDesk.Brush.Indigo}"
                      VerticalAlignment="Top"
                      Margin="0,5,0,0" />

              <TextBlock Grid.Column="1"
                         Text="{DynamicResource DashboardSafetyDisclaimerFull}"
                         TextWrapping="Wrap"
                         Foreground="{StaticResource GlucoDesk.Brush.TextSecondary}" />
            </Grid>
          </Border>

        </StackPanel>
      </Grid>
    </ScrollViewer>
  </Border>
</UserControl>
