<UserControl
    x:Class="GlucoDesk.Desktop.Views.Dashboard.DashboardView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:GlucoDesk.Desktop.Views.Dashboard.Controls">

  <Border Classes="page-shell">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <Grid RowDefinitions="Auto,*"
            Margin="30"
            RowSpacing="26"
            MaxWidth="1540"
            HorizontalAlignment="Stretch">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="24">
          <StackPanel Spacing="8">
            <TextBlock Text="GlucoDesk"
                       Classes="page-title" />

            <TextBlock Text="A calm desktop companion for glucose awareness"
                       Classes="secondary"
                       FontSize="16" />
          </StackPanel>

          <Border Grid.Column="1"
                  Classes="badge-accent"
                  VerticalAlignment="Top">
            <TextBlock Text="Private · local-first · companion"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}" />
          </Border>
        </Grid>

        <StackPanel Grid.Row="1"
                    Spacing="22">

          <Border Classes="hero-card">
            <Grid ColumnDefinitions="1.16*,0.84*"
                  ColumnSpacing="30">

              <StackPanel Grid.Column="0"
                          Spacing="22">
                <StackPanel Spacing="10">
                  <TextBlock Text="CURRENT GLUCOSE"
                             Classes="eyebrow" />

                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="18"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding LatestValueText}"
                               Classes="hero-value" />

                    <StackPanel Grid.Column="1"
                                Spacing="8"
                                VerticalAlignment="Center">
                      <Border Classes="status-pill-success"
                              HorizontalAlignment="Left">
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource GlucoDesk.Brush.Success}" />
                      </Border>

                      <TextBlock Text="{Binding TargetRangeText}"
                                 Classes="secondary"
                                 FontSize="13" />
                    </StackPanel>
                  </Grid>

                  <TextBlock Text="{Binding DataSourceStatusText}"
                             Classes="secondary"
                             FontSize="14"
                             TextWrapping="Wrap"
                             MaxWidth="780" />
                </StackPanel>

                <WrapPanel Orientation="Horizontal">
                  <Border Classes="signal-chip"
                          Margin="0,0,10,10">
                    <StackPanel Spacing="3">
                      <TextBlock Text="Trend"
                                 Classes="metric-label" />

                      <TextBlock Text="{Binding TrendText}"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource GlucoDesk.Brush.TextPrimary}" />
                    </StackPanel>
                  </Border>

                  <Border Classes="signal-chip"
                          Margin="0,0,10,10">
                    <StackPanel Spacing="3">
                      <TextBlock Text="Freshness"
                                 Classes="metric-label" />

                      <TextBlock Text="{Binding FreshnessText}"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource GlucoDesk.Brush.TextPrimary}" />
                    </StackPanel>
                  </Border>

                  <Border Classes="signal-chip"
                          Margin="0,0,10,10">
                    <StackPanel Spacing="3">
                      <TextBlock Text="Updated"
                                 Classes="metric-label" />

                      <TextBlock Text="{Binding LastUpdatedText}"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource GlucoDesk.Brush.TextPrimary}" />
                    </StackPanel>
                  </Border>
                </WrapPanel>
              </StackPanel>

              <Border Grid.Column="1"
                      Classes="hero-side-card"
                      VerticalAlignment="Stretch">
                <StackPanel Spacing="18"
                            HorizontalAlignment="Stretch">

                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="16">
                    <StackPanel Spacing="5">
                      <TextBlock Text="Dashboard refresh"
                                 Classes="section-title" />

                      <TextBlock Text="{Binding AutoRefreshStatusText}"
                                 Classes="secondary"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Refresh now"
                            Command="{Binding RefreshCommand}"
                            VerticalAlignment="Top" />
                  </Grid>

                  <Border Height="1"
                          Background="{StaticResource GlucoDesk.Brush.Border}" />

                  <StackPanel Spacing="10">
                    <Border Classes="refresh-row">
                      <TextBlock Text="{Binding SettingsStatusText}"
                                 Classes="secondary"
                                 TextWrapping="Wrap" />
                    </Border>

                    <Border Classes="refresh-row">
                      <TextBlock Text="{Binding HistoryStatusText}"
                                 Classes="secondary"
                                 TextWrapping="Wrap" />
                    </Border>
                  </StackPanel>
                </StackPanel>
              </Border>
            </Grid>
          </Border>

          <Grid ColumnDefinitions="*,*"
                ColumnSpacing="20">

            <Border Grid.Column="0"
                    Classes="signal-card">
              <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="16">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding ProviderStatusTitle}"
                               Classes="section-title" />

                    <TextBlock Text="Active glucose source"
                               Classes="muted"
                               FontSize="12" />
                  </StackPanel>

                  <Border Grid.Column="1"
                          Classes="badge"
                          VerticalAlignment="Top">
                    <TextBlock Text="{Binding ProviderStatusBadgeText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GlucoDesk.Brush.TextSecondary}" />
                  </Border>
                </Grid>

                <TextBlock Text="{Binding ProviderStatusMessage}"
                           TextWrapping="Wrap"
                           Classes="secondary"
                           FontSize="13" />
              </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Classes="signal-card">
              <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="16">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding DataHealthTitle}"
                               Classes="section-title" />

                    <TextBlock Text="Quality of the displayed data"
                               Classes="muted"
                               FontSize="12" />
                  </StackPanel>

                  <Border Grid.Column="1"
                          Classes="badge"
                          VerticalAlignment="Top">
                    <TextBlock Text="{Binding DataHealthBadgeText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GlucoDesk.Brush.TextSecondary}" />
                  </Border>
                </Grid>

                <TextBlock Text="{Binding DataHealthMessage}"
                           TextWrapping="Wrap"
                           Classes="secondary"
                           FontSize="13" />
              </StackPanel>
            </Border>
          </Grid>

          <Grid ColumnDefinitions="1.15*,0.85*"
                ColumnSpacing="20">

            <Border Grid.Column="0"
                    Classes="surface-card-strong">
              <StackPanel Spacing="18">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="18">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Glucose overview"
                               Classes="section-title" />

                    <TextBlock Text="{Binding StatisticsStatusText}"
                               TextWrapping="Wrap"
                               Classes="secondary"
                               FontSize="13" />
                  </StackPanel>

                  <Border Grid.Column="1"
                          Classes="badge-accent"
                          VerticalAlignment="Top">
                    <TextBlock Text="{Binding StatisticsReadingsAnalyzedText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}" />
                  </Border>
                </Grid>

                <WrapPanel Orientation="Horizontal">
                  <Border Classes="metric-card-accent"
                          Margin="0,0,12,12">
                    <StackPanel Spacing="5">
                      <TextBlock Text="Average"
                                 Classes="metric-label" />

                      <TextBlock Text="{Binding StatisticsAverageGlucoseText}"
                                 Classes="metric-value" />
                    </StackPanel>
                  </Border>

                  <Border Classes="metric-card-success"
                          Margin="0,0,12,12">
                    <StackPanel Spacing="5">
                      <TextBlock Text="Time in range"
                                 Classes="metric-label" />

                      <TextBlock Text="{Binding StatisticsTimeInRangeText}"
                                 Classes="metric-value" />
                    </StackPanel>
                  </Border>

                  <Border Classes="metric-card-danger"
                          Margin="0,0,12,12">
                    <StackPanel Spacing="5">
                      <TextBlock Text="Below range"
                                 Classes="metric-label" />

                      <TextBlock Text="{Binding StatisticsBelowRangeText}"
                                 Classes="metric-value" />
                    </StackPanel>
                  </Border>

                  <Border Classes="metric-card-warning"
                          Margin="0,0,12,12">
                    <StackPanel Spacing="5">
                      <TextBlock Text="Above range"
                                 Classes="metric-label" />

                      <TextBlock Text="{Binding StatisticsAboveRangeText}"
                                 Classes="metric-value" />
                    </StackPanel>
                  </Border>
                </WrapPanel>

                <TextBlock Text="{Binding StatisticsTargetRangeText}"
                           TextWrapping="Wrap"
                           Classes="muted"
                           FontSize="12" />
              </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Classes="surface-card">
              <StackPanel Spacing="18">
                <StackPanel Spacing="4">
                  <TextBlock Text="Session summary"
                             Classes="section-title" />

                  <TextBlock Text="A compact snapshot of the current dashboard refresh."
                             Classes="secondary"
                             FontSize="13"
                             TextWrapping="Wrap" />
                </StackPanel>

                <WrapPanel Orientation="Horizontal">
                  <Border Classes="metric-card"
                          Margin="0,0,12,12">
                    <StackPanel Spacing="5">
                      <TextBlock Text="Provider"
                                 Classes="metric-label" />

                      <TextBlock Text="{Binding ProviderDisplayName}"
                                 Classes="metric-value"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>

                  <Border Classes="metric-card"
                          Margin="0,0,12,12">
                    <StackPanel Spacing="5">
                      <TextBlock Text="Readings"
                                 Classes="metric-label" />

                      <TextBlock Text="{Binding RecentReadingsCountText}"
                                 Classes="metric-value" />
                    </StackPanel>
                  </Border>

                  <Border Classes="metric-card"
                          Margin="0,0,12,12">
                    <StackPanel Spacing="5">
                      <TextBlock Text="Updated"
                                 Classes="metric-label" />

                      <TextBlock Text="{Binding LastUpdatedText}"
                                 Classes="metric-value"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </WrapPanel>
              </StackPanel>
            </Border>
          </Grid>

          <Border Classes="chart-card">
            <StackPanel Spacing="18">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="18">
                <StackPanel Spacing="6">
                  <TextBlock Text="Recent glucose trend"
                             Classes="section-title" />

                  <TextBlock Text="{Binding TargetRangeText}"
                             Classes="muted" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Spacing="10"
                            HorizontalAlignment="Right">

                  <Border Classes="segmented-control"
                          HorizontalAlignment="Right">
                    <WrapPanel Orientation="Horizontal"
                               HorizontalAlignment="Right">
                      <Button Content="3H"
                              Command="{Binding SelectThreeHourChartWindowCommand}"
                              Classes="segment-button"
                              Classes.accent="{Binding IsThreeHourChartWindowSelected}"
                              MinWidth="48"
                              Padding="12,8"
                              Margin="0,0,6,0" />

                      <Button Content="6H"
                              Command="{Binding SelectSixHourChartWindowCommand}"
                              Classes="segment-button"
                              Classes.accent="{Binding IsSixHourChartWindowSelected}"
                              MinWidth="48"
                              Padding="12,8"
                              Margin="0,0,6,0" />

                      <Button Content="12H"
                              Command="{Binding SelectTwelveHourChartWindowCommand}"
                              Classes="segment-button"
                              Classes.accent="{Binding IsTwelveHourChartWindowSelected}"
                              MinWidth="54"
                              Padding="12,8" />

                      <Button Content="24H"
                              Command="{Binding ShowTwentyFourHourChartWindowCommand}"
                              Classes="segment-button"
                              Classes.accent="{Binding IsTwentyFourHourChartWindowSelected}"
                              MinWidth="54"
                              Padding="12,8" />
                    </WrapPanel>
                  </Border>

                  <TextBlock Text="{Binding ChartSummaryText}"
                             Classes="secondary"
                             TextAlignment="Right" />

                  <Border Classes="badge"
                          HorizontalAlignment="Right">
                    <TextBlock Text="{Binding LatestValueText}"
                               Classes="muted"
                               FontSize="12"
                               TextAlignment="Right" />
                  </Border>
                </StackPanel>
              </Grid>

              <Border Classes="chart-shell"
                      Height="340"
                      Padding="12">
                <controls:GlucoseTrendChart
                    Points="{Binding ChartPoints}"
                    TargetLowMgDl="{Binding TargetLowMgDl}"
                    TargetHighMgDl="{Binding TargetHighMgDl}"
                    WindowHours="{Binding SelectedChartWindowHours}"
                    MaxVisibleMgDl="{Binding ChartMaximumMgDl}" />
              </Border>
            </StackPanel>
          </Border>

          <Border Classes="notice-card-danger"
                  IsVisible="{Binding HasError}">
            <StackPanel Spacing="6">
              <TextBlock Text="Dashboard error"
                         Classes="section-title"
                         Foreground="{StaticResource GlucoDesk.Brush.Danger}" />

              <TextBlock Text="{Binding ErrorMessage}"
                         TextWrapping="Wrap"
                         Foreground="{StaticResource GlucoDesk.Brush.TextSecondary}" />
            </StackPanel>
          </Border>

          <Border Classes="notice-card-warning"
                  IsVisible="{Binding IsMockProviderActive}">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="14">
              <Border Classes="notice-dot-warning"
                      VerticalAlignment="Top" />

              <StackPanel Grid.Column="1"
                          Spacing="5">
                <TextBlock Text="Demo mode active"
                           Classes="section-title"
                           Foreground="{StaticResource GlucoDesk.Brush.Warning}" />

                <TextBlock Text="Mock provider is currently powering the dashboard. Configure and select Dexcom or Nightscout in Settings to use real provider data."
                           TextWrapping="Wrap"
                           Foreground="{StaticResource GlucoDesk.Brush.TextSecondary}" />
              </StackPanel>
            </Grid>
          </Border>

          <Border Classes="notice-card-info">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="14">
              <Border Classes="notice-dot-info"
                      VerticalAlignment="Top" />

              <TextBlock Grid.Column="1"
                         Text="GlucoDesk is not a medical device and must not be used for treatment decisions, insulin dosing, emergency alerts, or as a replacement for approved diabetes applications."
                         TextWrapping="Wrap"
                         Foreground="{StaticResource GlucoDesk.Brush.TextSecondary}" />
            </Grid>
          </Border>

        </StackPanel>
      </Grid>
    </ScrollViewer>
  </Border>
</UserControl>