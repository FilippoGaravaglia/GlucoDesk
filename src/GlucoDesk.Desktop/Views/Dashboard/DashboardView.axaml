<UserControl
    x:Class="GlucoDesk.Desktop.Views.Dashboard.DashboardView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:GlucoDesk.Desktop.Views.Dashboard.Controls">

  <Grid RowDefinitions="Auto,*"
        Margin="32"
        RowSpacing="24">

    <StackPanel Grid.Row="0"
                Spacing="8">
      <TextBlock Text="GlucoDesk"
                 FontSize="34"
                 FontWeight="SemiBold" />

      <TextBlock Text="Local-first CGM desktop companion"
                 FontSize="16"
                 Opacity="0.75" />
    </StackPanel>

    <Border Grid.Row="1"
            Padding="28"
            CornerRadius="16"
            BorderThickness="1">
      <StackPanel Spacing="20">

        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Spacing="4">
            <TextBlock Text="Current glucose"
                       FontSize="14"
                       Opacity="0.7" />

            <TextBlock Text="{Binding LatestValueText}"
                       FontSize="56"
                       FontWeight="Bold" />
          </StackPanel>

          <StackPanel Grid.Column="1"
                      Spacing="8"
                      VerticalAlignment="Top">
            <Button Content="Refresh now"
                    Command="{Binding RefreshCommand}" />

            <TextBlock Text="{Binding AutoRefreshStatusText}"
                       Opacity="0.65"
                       TextAlignment="Right" />

            <TextBlock Text="{Binding SettingsStatusText}"
                       Opacity="0.55"
                       TextAlignment="Right" />

            <TextBlock Text="{Binding HistoryStatusText}"
                       Opacity="0.55"
                       TextAlignment="Right" />

            <TextBlock Text="{Binding DataSourceStatusText}"
                       TextWrapping="Wrap"
                       Opacity="0.65"
                       TextAlignment="Right"
                       MaxWidth="360" />
          </StackPanel>
        </Grid>

        <Border Padding="16"
                      CornerRadius="14"
                      BorderThickness="1"
                      BorderBrush="#334155"
                      Background="#111827">
                      <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                          <TextBlock Grid.Column="0"
                                     Text="{Binding ProviderStatusTitle}"
                                     FontSize="16"
                                     FontWeight="SemiBold"
                                     VerticalAlignment="Center" />

                          <Border Grid.Column="1"
                                  Padding="10,4"
                                  CornerRadius="999"
                                  Background="#1F2937"
                                  BorderThickness="1"
                                  BorderBrush="#475569"
                                  VerticalAlignment="Center">
                            <TextBlock Text="{Binding ProviderStatusBadgeText}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                          </Border>
                        </Grid>

                        <TextBlock Text="{Binding ProviderStatusMessage}"
                                   TextWrapping="Wrap"
                                   Opacity="0.72"
                                   FontSize="13" />
                      </StackPanel>
        </Border>

        <Border Padding="16"
        CornerRadius="14"
        BorderThickness="1"
        BorderBrush="#334155"
        Background="#0F172A">
      <StackPanel Spacing="8">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0"
                    Text="{Binding DataHealthTitle}"
                    FontSize="16"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center" />

          <Border Grid.Column="1"
                  Padding="10,4"
                  CornerRadius="999"
                  Background="#1F2937"
                  BorderThickness="1"
                  BorderBrush="#475569"
                  VerticalAlignment="Center">
            <TextBlock Text="{Binding DataHealthBadgeText}"
                      FontSize="12"
                      FontWeight="SemiBold" />
          </Border>
        </Grid>

        <TextBlock Text="{Binding DataHealthMessage}"
                  TextWrapping="Wrap"
                  Opacity="0.72"
                  FontSize="13" />
      </StackPanel>
      </Border>

        <Grid ColumnDefinitions="*,*"
              RowDefinitions="Auto,Auto,Auto"
              ColumnSpacing="24"
              RowSpacing="14">

          <StackPanel Grid.Row="0"
                      Grid.Column="0"
                      Spacing="4">
            <TextBlock Text="Trend"
                       Opacity="0.7" />
            <TextBlock Text="{Binding TrendText}"
                       FontSize="18"
                       FontWeight="SemiBold" />
          </StackPanel>

          <StackPanel Grid.Row="0"
                      Grid.Column="1"
                      Spacing="4">
            <TextBlock Text="Status"
                       Opacity="0.7" />
            <TextBlock Text="{Binding StatusText}"
                       FontSize="18"
                       FontWeight="SemiBold" />
          </StackPanel>

          <StackPanel Grid.Row="1"
                      Grid.Column="0"
                      Spacing="4">
            <TextBlock Text="Provider"
                       Opacity="0.7" />
            <TextBlock Text="{Binding ProviderDisplayName}"
                       FontSize="18" />
          </StackPanel>

          <StackPanel Grid.Row="1"
                      Grid.Column="1"
                      Spacing="4">
            <TextBlock Text="Freshness"
                       Opacity="0.7" />
            <TextBlock Text="{Binding FreshnessText}"
                       FontSize="18" />
          </StackPanel>

          <StackPanel Grid.Row="2"
                      Grid.Column="0"
                      Spacing="4">
            <TextBlock Text="Last updated"
                       Opacity="0.7" />
            <TextBlock Text="{Binding LastUpdatedText}"
                       FontSize="18" />
          </StackPanel>

          <StackPanel Grid.Row="2"
                      Grid.Column="1"
                      Spacing="4">
            <TextBlock Text="Recent readings"
                       Opacity="0.7" />
            <TextBlock Text="{Binding RecentReadingsCountText}"
                       FontSize="18" />
          </StackPanel>
        </Grid>

        <StackPanel Spacing="8">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="2">
              <TextBlock Text="Recent glucose trend"
                         FontSize="16"
                         FontWeight="SemiBold" />

              <TextBlock Text="{Binding TargetRangeText}"
                         Opacity="0.65" />
            </StackPanel>

            <TextBlock Grid.Column="1"
                       Text="{Binding ChartSummaryText}"
                       Opacity="0.65" />
          </Grid>

          <Border Height="180"
                  CornerRadius="12"
                  BorderThickness="1"
                  Padding="8">
            <controls:GlucoseTrendChart
                Points="{Binding ChartPoints}"
                TargetLowMgDl="{Binding TargetLowMgDl}"
                TargetHighMgDl="{Binding TargetHighMgDl}" />
          </Border>
        </StackPanel>

        <TextBlock Text="{Binding ErrorMessage}"
                   IsVisible="{Binding HasError}"
                   TextWrapping="Wrap"
                   FontWeight="SemiBold" />

        <TextBlock Text="Demo data is currently provided by the Mock CGM provider. Configure and select Dexcom or Nightscout in Settings to use real provider data."
                   IsVisible="{Binding IsMockProviderActive}"
                   TextWrapping="Wrap"
                   Opacity="0.65" />

        <TextBlock Text="GlucoDesk is not a medical device and must not be used for treatment decisions, insulin dosing, emergency alerts, or as a replacement for approved diabetes applications."
                   TextWrapping="Wrap"
                   Opacity="0.65" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>