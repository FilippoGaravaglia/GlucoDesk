<UserControl
    x:Class="GlucoDesk.Desktop.Views.Settings.SettingsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border Classes="page-shell">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <Grid RowDefinitions="Auto,*"
            Margin="30"
            RowSpacing="26"
            MinWidth="860"
            MaxWidth="1680"
            HorizontalAlignment="Stretch">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="24">
          <StackPanel Spacing="8">
            <TextBlock Text="Settings"
                       Classes="page-title" />

            <TextBlock Text="Configure GlucoDesk preferences, providers and dashboard behavior."
                       Classes="secondary"
                       FontSize="16"
                       TextWrapping="Wrap" />
          </StackPanel>

          <Border Grid.Column="1"
                  Classes="badge-accent"
                  VerticalAlignment="Top">
            <TextBlock Text="Local preferences"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}" />
          </Border>
        </Grid>

        <StackPanel Grid.Row="1"
                    Spacing="22">

          <Border Classes="surface-card"
                  Padding="24">
            <Grid x:Name="ProvidersSectionGrid"
                  ColumnDefinitions="1.15*,0.85*"
                  RowDefinitions="Auto"
                  ColumnSpacing="34">

              <StackPanel Grid.Column="0"
                          Grid.Row="0"
                          Spacing="22">

                <StackPanel Spacing="4">
                  <TextBlock Text="CGM providers"
                             Classes="section-title" />

                  <TextBlock Text="Select which provider GlucoDesk should use for live and historical glucose data."
                             Classes="secondary"
                             FontSize="13"
                             TextWrapping="Wrap" />
                </StackPanel>

                <Border Padding="18"
                        CornerRadius="18"
                        BorderThickness="1"
                        BorderBrush="{StaticResource GlucoDesk.Brush.BorderSoft}"
                        Background="{StaticResource GlucoDesk.Brush.SurfaceSoft}">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Runtime availability"
                               Classes="metric-label" />

                    <TextBlock Text="{Binding ProviderAvailabilityStatusText}"
                               TextWrapping="Wrap"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GlucoDesk.Brush.TextPrimary}" />

                    <TextBlock Text="{Binding DexcomConnectionStatusText}"
                               TextWrapping="Wrap"
                               Classes="secondary"
                               FontWeight="SemiBold" />

                    <TextBlock Text="{Binding NightscoutConnectionStatusText}"
                               TextWrapping="Wrap"
                               Classes="secondary" />
                  </StackPanel>
                </Border>

                <WrapPanel Orientation="Horizontal">
                  <Button Content="Test Nightscout connection"
                          Command="{Binding TestNightscoutConnectionCommand}"
                          IsVisible="{Binding CanTestNightscoutConnection}"
                          Margin="0,0,10,10" />

                  <Button Content="Use Nightscout as active provider"
                          Command="{Binding UseNightscoutAsActiveProviderCommand}"
                          IsVisible="{Binding CanUseNightscoutProvider}"
                          Margin="0,0,10,10" />

                  <Button Content="Connect Dexcom"
                          Command="{Binding ConnectDexcomCommand}"
                          IsVisible="{Binding CanConnectDexcom}"
                          Margin="0,0,10,10" />
                </WrapPanel>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="20">
                  <StackPanel Grid.Column="0"
                              Spacing="8">
                    <TextBlock Text="Live provider"
                               Classes="metric-label" />

                    <ComboBox ItemsSource="{Binding ProviderOptions}"
                              SelectedItem="{Binding SelectedLiveProvider}"
                              HorizontalAlignment="Stretch" />
                  </StackPanel>

                  <StackPanel Grid.Column="1"
                              Spacing="8">
                    <TextBlock Text="Historical provider"
                               Classes="metric-label" />

                    <ComboBox ItemsSource="{Binding ProviderOptions}"
                              SelectedItem="{Binding SelectedHistoricalProvider}"
                              HorizontalAlignment="Stretch" />
                  </StackPanel>
                </Grid>

              </StackPanel>

              <Border x:Name="ProvidersRightPanel"
                      Grid.Column="1"
                      Grid.Row="0"
                      BorderThickness="1,0,0,0"
                      BorderBrush="{StaticResource GlucoDesk.Brush.BorderSoft}"
                      Padding="28,0,0,0">
                <StackPanel Spacing="18">

                  <StackPanel Spacing="4">
                    <TextBlock Text="Production notes"
                               Classes="section-title" />

                    <TextBlock Text="Provider tokens and OAuth secrets are intentionally not stored here yet."
                               Classes="secondary"
                               FontSize="13"
                               TextWrapping="Wrap" />
                  </StackPanel>

                  <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="12">
                      <Border Width="10"
                              Height="10"
                              CornerRadius="999"
                              Background="{StaticResource GlucoDesk.Brush.Indigo}"
                              VerticalAlignment="Top"
                              Margin="0,5,0,0" />

                      <StackPanel Grid.Column="1"
                                  Spacing="4">
                        <TextBlock Text="Secure storage required"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource GlucoDesk.Brush.Indigo}" />

                        <TextBlock Text="GlucoDesk currently stores only non-secret preferences in local JSON. Secret provider credentials should use secure storage in future production releases."
                                   TextWrapping="Wrap"
                                   Classes="secondary"
                                   FontSize="13" />
                      </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="12">
                      <Border Width="10"
                              Height="10"
                              CornerRadius="999"
                              Background="{StaticResource GlucoDesk.Brush.Warning}"
                              VerticalAlignment="Top"
                              Margin="0,5,0,0" />

                      <StackPanel Grid.Column="1"
                                  Spacing="4">
                        <TextBlock Text="Provider safety"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource GlucoDesk.Brush.Warning}" />

                        <TextBlock Text="Only providers available in the current desktop runtime can be selected safely. Mock is always available; Dexcom and Nightscout require explicit configuration."
                                   TextWrapping="Wrap"
                                   Classes="secondary"
                                   FontSize="13" />
                      </StackPanel>
                    </Grid>
                  </StackPanel>

                </StackPanel>
              </Border>

            </Grid>
          </Border>

          <Border Classes="surface-card"
                  Padding="24">
            <StackPanel Spacing="20">

              <Grid x:Name="PreferencesSectionGrid"
                    ColumnDefinitions="1.15*,0.85*"
                    RowDefinitions="Auto"
                    ColumnSpacing="34">

                <StackPanel Grid.Column="0"
                            Grid.Row="0"
                            Spacing="20">

                  <StackPanel Spacing="4">
                    <TextBlock Text="Glucose preferences"
                               Classes="section-title" />

                    <TextBlock Text="Set the preferred unit and target range used by the dashboard, statistics and chart rendering."
                               Classes="secondary"
                               FontSize="13"
                               TextWrapping="Wrap" />
                  </StackPanel>

                  <Grid ColumnDefinitions="*,*,*"
                        ColumnSpacing="20">

                    <StackPanel Grid.Column="0"
                                Spacing="8">
                      <TextBlock Text="Preferred unit"
                                 Classes="metric-label" />

                      <ComboBox ItemsSource="{Binding PreferredUnitOptions}"
                                SelectedItem="{Binding SelectedPreferredUnit}"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Spacing="8">
                      <TextBlock Text="Target low"
                                 Classes="metric-label" />

                      <TextBox Text="{Binding TargetLowMgDlText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               PlaceholderText="{Binding TargetLowPlaceholderText}"
                               TextChanged="OnTargetValueTextChanged"
                               HorizontalAlignment="Stretch" />

                      <TextBlock Text="{Binding TargetRangeUnitLabel}"
                                 Classes="muted"
                                 FontSize="12" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Spacing="8">
                      <TextBlock Text="Target high"
                                 Classes="metric-label" />

                      <TextBox Text="{Binding TargetHighMgDlText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               PlaceholderText="{Binding TargetHighPlaceholderText}"
                               TextChanged="OnTargetValueTextChanged"
                               HorizontalAlignment="Stretch" />

                      <TextBlock Text="{Binding TargetRangeUnitLabel}"
                                 Classes="muted"
                                 FontSize="12" />
                    </StackPanel>

                  </Grid>

                </StackPanel>

                <Border x:Name="PreferencesRightPanel"
                        Grid.Column="1"
                        Grid.Row="0"
                        BorderThickness="1,0,0,0"
                        BorderBrush="{StaticResource GlucoDesk.Brush.BorderSoft}"
                        Padding="28,0,0,0">
                  <StackPanel Spacing="20">

                    <StackPanel Spacing="4">
                      <TextBlock Text="Dashboard behavior"
                                 Classes="section-title" />

                      <TextBlock Text="Configure refresh frequency and glucose chart scale."
                                 Classes="secondary"
                                 FontSize="13"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                      <TextBlock Text="Refresh interval"
                                 Classes="metric-label" />

                      <TextBox Text="{Binding DashboardRefreshIntervalSecondsText}"
                               PlaceholderText="30"
                               HorizontalAlignment="Stretch" />

                      <TextBlock Text="seconds"
                                 Classes="muted"
                                 FontSize="12" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                      <TextBlock Text="Chart maximum"
                                 Classes="metric-label" />

                      <ComboBox ItemsSource="{Binding ChartMaximumOptions}"
                                SelectedValue="{Binding SelectedChartMaximumMgDl, Mode=TwoWay}"
                                SelectedValueBinding="{Binding ValueMgDl}"
                                HorizontalAlignment="Stretch" />

                      <TextBlock Text="{Binding ChartMaximumUnitLabel}"
                                 Classes="muted"
                                 FontSize="12" />
                    </StackPanel>

                  </StackPanel>
                </Border>

              </Grid>

              <Border Height="1"
                      Background="{StaticResource GlucoDesk.Brush.BorderSoft}" />

              <Grid x:Name="NotificationsSectionGrid"
                    ColumnDefinitions="1.15*,0.85*"
                    RowDefinitions="Auto"
                    ColumnSpacing="34">

                <StackPanel Grid.Column="0"
                            Grid.Row="0"
                            Spacing="18">

                  <StackPanel Spacing="4">
                    <TextBlock Text="Glucose awareness notifications"
                               Classes="section-title" />

                    <TextBlock Text="Show calm, non-medical desktop awareness messages when glucose is outside your configured target range."
                               Classes="secondary"
                               FontSize="13"
                               TextWrapping="Wrap" />
                  </StackPanel>

                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="20">
                    <CheckBox Grid.Column="0"
                              Content="Enable in-app banner"
                              IsChecked="{Binding GlucoseAlertsEnabled}" />

                    <CheckBox Grid.Column="1"
                              Content="Use privacy wording"
                              IsChecked="{Binding GlucoseAlertPrivacyModeEnabled}"
                              IsEnabled="{Binding GlucoseAlertsEnabled}" />
                  </Grid>

                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="20">
                    <CheckBox Grid.Column="0"
                              Content="Notify below target"
                              IsChecked="{Binding LowGlucoseAlertsEnabled}"
                              IsEnabled="{Binding GlucoseAlertsEnabled}" />

                    <CheckBox Grid.Column="1"
                              Content="Notify above target"
                              IsChecked="{Binding HighGlucoseAlertsEnabled}"
                              IsEnabled="{Binding GlucoseAlertsEnabled}" />
                  </Grid>

                  <TextBlock Text="GlucoDesk notifications are awareness prompts only. Keep using official diabetes apps and devices for therapy decisions and urgent alerts."
                             Classes="muted"
                             FontSize="12"
                             TextWrapping="Wrap" />
                </StackPanel>

                <Border x:Name="NotificationsRightPanel"
                        Grid.Column="1"
                        Grid.Row="0"
                        BorderThickness="1,0,0,0"
                        BorderBrush="{StaticResource GlucoDesk.Brush.BorderSoft}"
                        Padding="28,0,0,0">
                  <StackPanel Spacing="18">

                    <StackPanel Spacing="4">
                      <TextBlock Text="Anti-spam and OS notifications"
                                 Classes="section-title" />

                      <TextBlock Text="Native notifications are optional and protected by a repeat cooldown."
                                 Classes="secondary"
                                 FontSize="13"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                      <TextBlock Text="Consecutive readings required"
                                 Classes="label" />

                      <TextBox Text="{Binding GlucoseAlertRequiredConsecutiveReadingsText}"
                               IsEnabled="{Binding GlucoseAlertsEnabled}" />

                      <TextBlock Text="Number of consecutive out-of-range readings required before showing an alert. Use 1 for faster alerts, 2 as balanced default, or 3-5 to reduce noise."
                                 Classes="muted"
                                 FontSize="12"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                    <CheckBox Content="Enable native OS notifications"
                              IsChecked="{Binding NativeGlucoseNotificationsEnabled}"
                              IsEnabled="{Binding GlucoseAlertsEnabled}" />

                    <TextBlock Text="{Binding NativeNotificationDiagnosticsText}"
                               TextWrapping="Wrap"
                               Opacity="0.72"
                               Margin="0,4,0,0" />

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="14">
                      <Button Grid.Column="0"
                              Content="Send test notification"
                              Command="{Binding SendNativeGlucoseTestNotificationCommand}"
                              IsEnabled="{Binding CanSendNativeGlucoseTestNotification}" />

                      <TextBlock Grid.Column="1"
                                 Text="{Binding NativeGlucoseTestNotificationStatusText}"
                                 Classes="muted"
                                 FontSize="12"
                                 TextWrapping="Wrap"
                                 VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Spacing="8">
                      <TextBlock Text="Repeat cooldown"
                                 Classes="metric-label" />

                      <TextBox Text="{Binding GlucoseAlertRepeatIntervalMinutesText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               PlaceholderText="30"
                               HorizontalAlignment="Stretch"
                               IsEnabled="{Binding GlucoseAlertsEnabled}" />

                      <TextBlock Text="minutes between repeated notifications for the same condition"
                                 Classes="muted"
                                 FontSize="12"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                  </StackPanel>
                </Border>
              </Grid>

              <Border Height="1"
                      Background="{StaticResource GlucoDesk.Brush.BorderSoft}" />

              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="18"
                    VerticalAlignment="Center">
                <Button Grid.Column="0"
                        Content="Save settings"
                        Command="{Binding SaveCommand}"
                        VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Spacing="8"
                            VerticalAlignment="Center">
                  <TextBlock Text="{Binding StatusMessage}"
                             Classes="secondary"
                             TextWrapping="Wrap"
                             VerticalAlignment="Center" />

                  <Border IsVisible="{Binding HasError}"
                          Background="{StaticResource GlucoDesk.Brush.DangerSoft}"
                          BorderBrush="{StaticResource GlucoDesk.Brush.Danger}"
                          BorderThickness="1"
                          CornerRadius="14"
                          Padding="14">
                    <TextBlock Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GlucoDesk.Brush.Danger}" />
                  </Border>
                </StackPanel>
              </Grid>

            </StackPanel>
          </Border>

        </StackPanel>
      </Grid>
    </ScrollViewer>
  </Border>
</UserControl>
