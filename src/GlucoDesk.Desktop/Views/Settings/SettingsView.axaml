<UserControl
    x:Class="GlucoDesk.Desktop.Views.Settings.SettingsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border Classes="page-shell">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <Grid RowDefinitions="Auto,*"
            Margin="30"
            RowSpacing="26"
            MaxWidth="1540"
            HorizontalAlignment="Stretch">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="24">
          <StackPanel Spacing="8">
            <TextBlock Text="Settings"
                       Classes="page-title" />

            <TextBlock Text="Configure GlucoDesk preferences, providers and dashboard behavior."
                       Classes="secondary"
                       FontSize="16"
                       TextWrapping="Wrap" />
          </StackPanel>

          <Border Grid.Column="1"
                  Classes="badge-accent"
                  VerticalAlignment="Top">
            <TextBlock Text="Local preferences"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}" />
          </Border>
        </Grid>

        <StackPanel Grid.Row="1"
                    Spacing="22">

          <Grid ColumnDefinitions="1.1*,0.9*"
                ColumnSpacing="20">

            <Border Grid.Column="0"
                    Classes="surface-card-strong">
              <StackPanel Spacing="18">

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="16">
                  <StackPanel Spacing="4">
                    <TextBlock Text="CGM providers"
                               Classes="section-title" />

                    <TextBlock Text="Select which provider GlucoDesk should use for live and historical glucose data."
                               Classes="secondary"
                               FontSize="13"
                               TextWrapping="Wrap" />
                  </StackPanel>

                  <Border Grid.Column="1"
                          Classes="badge-accent"
                          VerticalAlignment="Top">
                    <TextBlock Text="Provider routing"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}" />
                  </Border>
                </Grid>

                <Border Classes="metric-card-accent"
                        MinWidth="0">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Runtime availability"
                               Classes="metric-label" />

                    <TextBlock Text="{Binding ProviderAvailabilityStatusText}"
                               TextWrapping="Wrap"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GlucoDesk.Brush.TextPrimary}" />

                    <TextBlock Text="{Binding DexcomConnectionStatusText}"
                               TextWrapping="Wrap"
                               Classes="secondary"
                               FontWeight="SemiBold" />

                    <TextBlock Text="{Binding NightscoutConnectionStatusText}"
                               TextWrapping="Wrap"
                               Classes="secondary" />
                  </StackPanel>
                </Border>

                <WrapPanel Orientation="Horizontal">
                  <Button Content="Test Nightscout connection"
                          Command="{Binding TestNightscoutConnectionCommand}"
                          IsVisible="{Binding CanTestNightscoutConnection}"
                          Margin="0,0,10,10" />

                  <Button Content="Use Nightscout as active provider"
                          Command="{Binding UseNightscoutAsActiveProviderCommand}"
                          IsVisible="{Binding CanUseNightscoutProvider}"
                          Margin="0,0,10,10" />

                  <Button Content="Connect Dexcom"
                          Command="{Binding ConnectDexcomCommand}"
                          IsVisible="{Binding CanConnectDexcom}"
                          Margin="0,0,10,10" />
                </WrapPanel>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="18">
                  <Border Grid.Column="0"
                          Classes="metric-card"
                          MinWidth="0">
                    <StackPanel Spacing="8">
                      <TextBlock Text="Live provider"
                                 Classes="metric-label" />

                      <ComboBox ItemsSource="{Binding ProviderOptions}"
                                SelectedItem="{Binding SelectedLiveProvider}"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>
                  </Border>

                  <Border Grid.Column="1"
                          Classes="metric-card"
                          MinWidth="0">
                    <StackPanel Spacing="8">
                      <TextBlock Text="Historical provider"
                                 Classes="metric-label" />

                      <ComboBox ItemsSource="{Binding ProviderOptions}"
                                SelectedItem="{Binding SelectedHistoricalProvider}"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>
                  </Border>
                </Grid>

              </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Classes="surface-card">
              <StackPanel Spacing="18">

                <StackPanel Spacing="4">
                  <TextBlock Text="Production note"
                             Classes="section-title" />

                  <TextBlock Text="Provider tokens and OAuth secrets are intentionally not stored here yet."
                             Classes="secondary"
                             FontSize="13"
                             TextWrapping="Wrap" />
                </StackPanel>

                <Border Classes="sidebar-note-card"
                        Background="{StaticResource GlucoDesk.Brush.IndigoSoft}">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Secure storage required"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GlucoDesk.Brush.Indigo}" />

                    <TextBlock Text="GlucoDesk currently stores only non-secret preferences in local JSON. Secret provider credentials should use secure storage in future production releases."
                               TextWrapping="Wrap"
                               Classes="sidebar-note" />
                  </StackPanel>
                </Border>

                <Border Classes="sidebar-note-card"
                        Background="{StaticResource GlucoDesk.Brush.WarningSoft}">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Provider safety"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GlucoDesk.Brush.Warning}" />

                    <TextBlock Text="Only providers available in the current desktop runtime can be selected safely. Mock is always available; Dexcom and Nightscout require explicit configuration."
                               TextWrapping="Wrap"
                               Classes="sidebar-note" />
                  </StackPanel>
                </Border>

              </StackPanel>
            </Border>

          </Grid>

          <Grid ColumnDefinitions="1.1*,0.9*"
                ColumnSpacing="20">

            <Border Grid.Column="0"
                    Classes="surface-card-strong">
              <StackPanel Spacing="18">

                <StackPanel Spacing="4">
                  <TextBlock Text="Glucose preferences"
                             Classes="section-title" />

                  <TextBlock Text="Set preferred glucose unit and the target range used by the dashboard, statistics and chart rendering."
                             Classes="secondary"
                             FontSize="13"
                             TextWrapping="Wrap" />
                </StackPanel>

                <Grid ColumnDefinitions="*,*,*"
                      ColumnSpacing="18">
                  <Border Grid.Column="0"
                          Classes="metric-card"
                          MinWidth="0">
                    <StackPanel Spacing="8">
                      <TextBlock Text="Preferred unit"
                                 Classes="metric-label" />

                      <ComboBox ItemsSource="{Binding PreferredUnitOptions}"
                                SelectedItem="{Binding SelectedPreferredUnit}"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>
                  </Border>

                  <Border Grid.Column="1"
                          Classes="metric-card"
                          MinWidth="0">
                    <StackPanel Spacing="8">
                      <TextBlock Text="Target low"
                                 Classes="metric-label" />

                      <TextBox Text="{Binding TargetLowMgDlText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               PlaceholderText="{Binding TargetLowPlaceholderText}"
                               TextChanged="OnTargetValueTextChanged"
                               HorizontalAlignment="Stretch" />

                      <TextBlock Text="{Binding TargetRangeUnitLabel}"
                                 Classes="muted"
                                 FontSize="12" />
                    </StackPanel>
                  </Border>

                  <Border Grid.Column="2"
                          Classes="metric-card"
                          MinWidth="0">
                    <StackPanel Spacing="8">
                      <TextBlock Text="Target high"
                                 Classes="metric-label" />

                      <TextBox Text="{Binding TargetHighMgDlText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               PlaceholderText="{Binding TargetHighPlaceholderText}"
                               TextChanged="OnTargetValueTextChanged"
                               HorizontalAlignment="Stretch" />

                      <TextBlock Text="{Binding TargetRangeUnitLabel}"
                                 Classes="muted"
                                 FontSize="12" />
                    </StackPanel>
                  </Border>
                </Grid>

              </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Classes="surface-card-strong">
              <StackPanel Spacing="18">

                <StackPanel Spacing="4">
                  <TextBlock Text="Dashboard behavior"
                             Classes="section-title" />

                  <TextBlock Text="Configure how frequently the dashboard refreshes and how the glucose chart is scaled."
                             Classes="secondary"
                             FontSize="13"
                             TextWrapping="Wrap" />
                </StackPanel>

                <Border Classes="metric-card-accent"
                        MinWidth="0">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Refresh interval"
                               Classes="metric-label" />

                    <TextBox Text="{Binding DashboardRefreshIntervalSecondsText}"
                             PlaceholderText="30"
                             HorizontalAlignment="Stretch" />

                    <TextBlock Text="seconds"
                               Classes="muted"
                               FontSize="12" />
                  </StackPanel>
                </Border>

                <Border Classes="metric-card"
                        MinWidth="0">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Chart maximum"
                               Classes="metric-label" />

                    <ComboBox ItemsSource="{Binding ChartMaximumOptions}"
                              SelectedValue="{Binding SelectedChartMaximumMgDl, Mode=TwoWay}"
                              SelectedValueBinding="{Binding ValueMgDl}"
                              HorizontalAlignment="Stretch" />

                    <TextBlock Text="{Binding ChartMaximumUnitLabel}"
                               Classes="muted"
                               FontSize="12" />
                  </StackPanel>
                </Border>

              </StackPanel>
            </Border>

          </Grid>

          <Border Classes="surface-card">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="18"
                  VerticalAlignment="Center">
              <Button Grid.Column="0"
                      Content="Save settings"
                      Command="{Binding SaveCommand}"
                      VerticalAlignment="Center" />

              <StackPanel Grid.Column="1"
                          Spacing="8"
                          VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusMessage}"
                           Classes="secondary"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />

                <Border IsVisible="{Binding HasError}"
                        Background="{StaticResource GlucoDesk.Brush.DangerSoft}"
                        BorderBrush="{StaticResource GlucoDesk.Brush.Danger}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14">
                  <TextBlock Text="{Binding ErrorMessage}"
                             TextWrapping="Wrap"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource GlucoDesk.Brush.Danger}" />
                </Border>
              </StackPanel>
            </Grid>
          </Border>

        </StackPanel>
      </Grid>
    </ScrollViewer>
  </Border>
</UserControl>