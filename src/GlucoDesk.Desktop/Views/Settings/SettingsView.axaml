<UserControl
    x:Class="GlucoDesk.Desktop.Views.Settings.SettingsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border Classes="page-shell">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <Grid RowDefinitions="Auto,*"
            Margin="30"
            RowSpacing="26"
            MinWidth="860"
            MaxWidth="1680"
            HorizontalAlignment="Stretch">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="24">
          <StackPanel Spacing="8">
            <TextBlock Text="{DynamicResource NavSettings}"
                       Classes="page-title" />

            <TextBlock Text="{DynamicResource SettingsSubtitle}"
                       Classes="secondary"
                       FontSize="16"
                       TextWrapping="Wrap" />
          </StackPanel>

          <Border MinWidth="260" Grid.Column="1"
                  Classes="badge-accent"
                  VerticalAlignment="Top">
            <TextBlock Text="{DynamicResource SettingsLocalPreferences}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}" />
          </Border>
        </Grid>

        <StackPanel Grid.Row="1"
                    Spacing="22">

          <Border Classes="surface-card"
                  Padding="24">
            <Grid x:Name="ProvidersSectionGrid"
                  ColumnDefinitions="1.15*,0.85*"
                  RowDefinitions="Auto"
                  ColumnSpacing="34">

              <StackPanel Grid.Column="0"
                          Grid.Row="0"
                          Spacing="22">

                <StackPanel Spacing="4">
                  <TextBlock Text="{DynamicResource SettingsCgmProvidersTitle}"
                             Classes="section-title" />

                  <TextBlock Text="{DynamicResource SettingsCgmProvidersSubtitle}"
                             Classes="secondary"
                             FontSize="13"
                             TextWrapping="Wrap" />
                </StackPanel>

                <Border Padding="18"
                        CornerRadius="18"
                        BorderThickness="1"
                        BorderBrush="{StaticResource GlucoDesk.Brush.BorderSoft}"
                        Background="{StaticResource GlucoDesk.Brush.SurfaceSoft}">
                  <StackPanel Spacing="8">
                    <TextBlock Text="{DynamicResource SettingsRuntimeAvailability}"
                               Classes="metric-label" />

                    <TextBlock Text="{Binding ProviderAvailabilityStatusText}"
                               TextWrapping="Wrap"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GlucoDesk.Brush.TextPrimary}" />

                    <TextBlock Text="{Binding DexcomConnectionStatusText}"
                               TextWrapping="Wrap"
                               Classes="secondary"
                               FontWeight="SemiBold" />

                    <TextBlock Text="{Binding NightscoutConnectionStatusText}"
                               TextWrapping="Wrap"
                               Classes="secondary" />
                  </StackPanel>
                </Border>

                <WrapPanel Orientation="Horizontal">
                  <Button Content="Test Nightscout connection"
                          Command="{Binding TestNightscoutConnectionCommand}"
                          IsVisible="{Binding CanTestNightscoutConnection}"
                          Margin="0,0,10,10" />

                  <Button Content="Use Nightscout as active provider"
                          Command="{Binding UseNightscoutAsActiveProviderCommand}"
                          IsVisible="{Binding CanUseNightscoutProvider}"
                          Margin="0,0,10,10" />

                  <Button Content="Connect Dexcom"
                          Command="{Binding ConnectDexcomCommand}"
                          IsVisible="{Binding CanConnectDexcom}"
                          Margin="0,0,10,10" />
                </WrapPanel>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="20">
                  <StackPanel Grid.Column="0"
                              Spacing="8">
                    <TextBlock Text="{DynamicResource SettingsLiveProvider}"
                               Classes="metric-label" />

                    <ComboBox ItemsSource="{Binding ProviderOptions}"
                              SelectedItem="{Binding SelectedLiveProvider, Mode=TwoWay}"
                              HorizontalAlignment="Stretch" />
                  </StackPanel>

                  <StackPanel Grid.Column="1"
                              Spacing="8">
                    <TextBlock Text="{DynamicResource SettingsHistoricalProvider}"
                               Classes="metric-label" />

                    <ComboBox ItemsSource="{Binding ProviderOptions}"
                              SelectedItem="{Binding SelectedHistoricalProvider, Mode=TwoWay}"
                              HorizontalAlignment="Stretch" />
                  </StackPanel>
                </Grid>

              </StackPanel>

              <Border MinWidth="260" x:Name="ProvidersRightPanel"
                      Grid.Column="1"
                      Grid.Row="0"
                      BorderThickness="1,0,0,0"
                      BorderBrush="{StaticResource GlucoDesk.Brush.BorderSoft}"
                      Padding="28,0,0,0">
                <StackPanel Spacing="18">

                  <StackPanel Spacing="4">
                    <TextBlock Text="{DynamicResource SettingsProductionNotes}"
                               Classes="section-title" />

                    <TextBlock Text="{DynamicResource SettingsProductionNotesDescription}"
                               Classes="secondary"
                               FontSize="13"
                               TextWrapping="Wrap" />
                  </StackPanel>

                  <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="12">
                      <Border Width="10"
                              Height="10"
                              CornerRadius="999"
                              Background="{StaticResource GlucoDesk.Brush.Indigo}"
                              VerticalAlignment="Top"
                              Margin="0,5,0,0" />

                      <StackPanel Grid.Column="1"
                                  Spacing="4">
                        <TextBlock Text="{DynamicResource SettingsSecureStorageRequired}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource GlucoDesk.Brush.Indigo}" />

                        <TextBlock Text="{DynamicResource SettingsSecureStorageDescription}"
                                   TextWrapping="Wrap"
                                   Classes="secondary"
                                   FontSize="13" />
                      </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="12">
                      <Border Width="10"
                              Height="10"
                              CornerRadius="999"
                              Background="{StaticResource GlucoDesk.Brush.Warning}"
                              VerticalAlignment="Top"
                              Margin="0,5,0,0" />

                      <StackPanel Grid.Column="1"
                                  Spacing="4">
                        <TextBlock Text="{DynamicResource SettingsProviderSafety}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource GlucoDesk.Brush.Warning}" />

                        <TextBlock Text="{DynamicResource SettingsProviderSafetyDescription}"
                                   TextWrapping="Wrap"
                                   Classes="secondary"
                                   FontSize="13" />
                      </StackPanel>
                    </Grid>
                  </StackPanel>

                </StackPanel>
              </Border>

            </Grid>
          </Border>

          <Border Classes="surface-card"
                  Padding="24">
            <StackPanel Spacing="20">

              <Grid x:Name="PreferencesSectionGrid"
                    ColumnDefinitions="1.15*,0.85*"
                    RowDefinitions="Auto"
                    ColumnSpacing="34">

                <StackPanel Grid.Column="0"
                            Grid.Row="0"
                            Spacing="20">

                  <StackPanel Spacing="4">
                    <TextBlock Text="{DynamicResource SettingsGlucosePreferencesTitle}"
                               Classes="section-title" />

                    <TextBlock Text="{DynamicResource SettingsGlucosePreferencesSubtitle}"
                               Classes="secondary"
                               FontSize="13"
                               TextWrapping="Wrap" />

                        <StackPanel Spacing="8" Margin="0,18,0,0">
                            <TextBlock Text="{DynamicResource LanguageSettingsTitle}"
                                       FontWeight="SemiBold" />
                            <ComboBox Name="AppLanguageComboBox"
                                      MinWidth="220"
                                      SelectionChanged="OnAppLanguageSelectionChanged" />
                            <TextBlock Text="{DynamicResource LanguageSettingsDescription}"
                                       TextWrapping="Wrap"
                                       Opacity="0.78" />
                        </StackPanel>
                  </StackPanel>

                  <Grid ColumnDefinitions="*,*,*"
                        ColumnSpacing="20">

                    <StackPanel Grid.Column="0"
                                Spacing="8">
                      <TextBlock Text="{DynamicResource SettingsPreferredUnit}"
                                 Classes="metric-label" />

                      <ComboBox ItemsSource="{Binding PreferredUnitOptions}"
                                SelectedItem="{Binding SelectedPreferredUnit, Mode=TwoWay}"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Spacing="8">
                      <TextBlock Text="{DynamicResource SettingsTargetLow}"
                                 Classes="metric-label" />

                      <TextBox Text="{Binding TargetLowMgDlText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               PlaceholderText="{Binding TargetLowPlaceholderText}"
                               TextChanged="OnTargetValueTextChanged"
                               HorizontalAlignment="Stretch" />

                      <TextBlock Text="{Binding TargetRangeUnitLabel}"
                                 Classes="muted"
                                 FontSize="12" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Spacing="8">
                      <TextBlock Text="{DynamicResource SettingsTargetHigh}"
                                 Classes="metric-label" />

                      <TextBox Text="{Binding TargetHighMgDlText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               PlaceholderText="{Binding TargetHighPlaceholderText}"
                               TextChanged="OnTargetValueTextChanged"
                               HorizontalAlignment="Stretch" />

                      <TextBlock Text="{Binding TargetRangeUnitLabel}"
                                 Classes="muted"
                                 FontSize="12" />
                    </StackPanel>

                  </Grid>

                </StackPanel>

                <Border MinWidth="260" x:Name="PreferencesRightPanel"
                        Grid.Column="1"
                        Grid.Row="0"
                        BorderThickness="1,0,0,0"
                        BorderBrush="{StaticResource GlucoDesk.Brush.BorderSoft}"
                        Padding="28,0,0,0">
                  <StackPanel Spacing="20">

                    <StackPanel Spacing="4">
                      <TextBlock Text="{DynamicResource SettingsDashboardBehaviorTitle}"
                                 Classes="section-title" />

                      <TextBlock Text="{DynamicResource SettingsDashboardBehaviorSubtitle}"
                                 Classes="secondary"
                                 FontSize="13"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                      <TextBlock Text="{DynamicResource SettingsRefreshInterval}"
                                 Classes="metric-label" />

                      <TextBox x:Name="DashboardRefreshIntervalSecondsTextBox"
                               Text="{Binding DashboardRefreshIntervalSecondsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               TextChanged="OnPositiveIntegerSettingsTextChanged"
                               PlaceholderText="30"
                               HorizontalAlignment="Stretch" />

                      <TextBlock Text="{DynamicResource SettingsSeconds}"
                                 Classes="muted"
                                 FontSize="12" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                      <TextBlock Text="{DynamicResource SettingsChartMaximum}"
                                 Classes="metric-label" />

                      <ComboBox ItemsSource="{Binding ChartMaximumOptions}"
                                SelectedValue="{Binding SelectedChartMaximumMgDl, Mode=TwoWay}"
                                SelectedValueBinding="{Binding ValueMgDl}"
                                HorizontalAlignment="Stretch" />

                      <TextBlock Text="{Binding ChartMaximumUnitLabel}"
                                 Classes="muted"
                                 FontSize="12" />
                    </StackPanel>

                  </StackPanel>
                </Border>

              </Grid>

              <Border Height="1"
                      Background="{StaticResource GlucoDesk.Brush.BorderSoft}" />

              <Grid x:Name="NotificationsSectionGrid"
                    ColumnDefinitions="1.15*,0.85*"
                    RowDefinitions="Auto"
                    ColumnSpacing="34">

                <StackPanel Grid.Column="0"
                            Grid.Row="0"
                            Spacing="18">

                  <StackPanel Spacing="4">
                    <TextBlock Text="{DynamicResource SettingsGlucoseAwarenessNotificationsTitle}"
                               Classes="section-title" />

                    <TextBlock Text="{DynamicResource SettingsGlucoseAwarenessNotificationsSubtitle}"
                               Classes="secondary"
                               FontSize="13"
                               TextWrapping="Wrap" />
                  </StackPanel>

                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="20">
                    <CheckBox Grid.Column="0"
                              Content="{DynamicResource SettingsEnableInAppBanner}"
                              IsChecked="{Binding GlucoseAlertsEnabled, Mode=TwoWay}" />

                    <CheckBox Grid.Column="1"
                              Content="{DynamicResource SettingsUsePrivacyWording}"
                              IsChecked="{Binding GlucoseAlertPrivacyModeEnabled, Mode=TwoWay}"
                              IsEnabled="{Binding GlucoseAlertsEnabled}" />
                  </Grid>

                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="20">
                    <CheckBox Grid.Column="0"
                              Content="{DynamicResource SettingsNotifyBelowTarget}"
                              IsChecked="{Binding LowGlucoseAlertsEnabled, Mode=TwoWay}"
                              IsEnabled="{Binding GlucoseAlertsEnabled}" />

                    <CheckBox Grid.Column="1"
                              Content="{DynamicResource SettingsNotifyAboveTarget}"
                              IsChecked="{Binding HighGlucoseAlertsEnabled, Mode=TwoWay}"
                              IsEnabled="{Binding GlucoseAlertsEnabled}" />
                  </Grid>

                  <TextBlock Text="{DynamicResource SettingsNotificationsSafetyNote}"
                             Classes="muted"
                             FontSize="12"
                             TextWrapping="Wrap" />
                </StackPanel>

                <Border MinWidth="260" x:Name="NotificationsRightPanel"
                        Grid.Column="1"
                        Grid.Row="0"
                        BorderThickness="1,0,0,0"
                        BorderBrush="{StaticResource GlucoDesk.Brush.BorderSoft}"
                        Padding="28,0,0,0">
                  <StackPanel Spacing="18">

                    <StackPanel Spacing="4">
                      <TextBlock Text="{DynamicResource SettingsAntiSpamTitle}"
                                 Classes="section-title" />

                      <TextBlock Text="{DynamicResource SettingsAntiSpamSubtitle}"
                                 Classes="secondary"
                                 FontSize="13"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                      <TextBlock Text="{DynamicResource SettingsConsecutiveReadingsRequired}"
                                 Classes="label" />

                      <TextBox x:Name="GlucoseAlertRequiredConsecutiveReadingsTextBox"
                               Text="{Binding GlucoseAlertRequiredConsecutiveReadingsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               TextChanged="OnPositiveIntegerSettingsTextChanged"
                               IsEnabled="{Binding GlucoseAlertsEnabled}" />

                      <TextBlock Text="{DynamicResource SettingsConsecutiveReadingsDescription}"
                                 Classes="muted"
                                 FontSize="12"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                    <CheckBox Content="{DynamicResource SettingsEnableNativeNotifications}"
                              IsChecked="{Binding NativeGlucoseNotificationsEnabled, Mode=TwoWay}"
                              IsEnabled="{Binding GlucoseAlertsEnabled}" />

                    <TextBlock Text="{Binding NativeNotificationDiagnosticsText}"
                               TextWrapping="Wrap"
                               Opacity="0.72"
                               Margin="0,4,0,0" />

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="14">
                      <Button Grid.Column="0"
                              Content="{DynamicResource SettingsSendTestNotification}"
                              Command="{Binding SendNativeGlucoseTestNotificationCommand}"
                              IsEnabled="{Binding CanSendNativeGlucoseTestNotification}" />

                      <TextBlock Grid.Column="1"
                                 Text="{Binding NativeGlucoseTestNotificationStatusText}"
                                 Classes="muted"
                                 FontSize="12"
                                 TextWrapping="Wrap"
                                 VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Spacing="8">
                      <TextBlock Text="{DynamicResource SettingsRepeatCooldown}"
                                 Classes="metric-label" />

                      <TextBox x:Name="GlucoseAlertRepeatIntervalMinutesTextBox"
                               Text="{Binding GlucoseAlertRepeatIntervalMinutesText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               TextChanged="OnPositiveIntegerSettingsTextChanged"
                               PlaceholderText="30"
                               HorizontalAlignment="Stretch"
                               IsEnabled="{Binding GlucoseAlertsEnabled}" />

                      <TextBlock Text="{DynamicResource SettingsRepeatCooldownDescription}"
                                 Classes="muted"
                                 FontSize="12"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                  </StackPanel>
                </Border>
              </Grid>

              <Border Height="1"
                      Background="{StaticResource GlucoDesk.Brush.BorderSoft}" />

              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="18"
                    VerticalAlignment="Center">
                <Button Grid.Column="0"
                        Content="{DynamicResource SettingsSaveButton}"
                        Command="{Binding SaveCommand}"
                        VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Spacing="8"
                            VerticalAlignment="Center">
                  <TextBlock Text="{Binding StatusMessage}"
                             Classes="secondary"
                             TextWrapping="Wrap"
                             VerticalAlignment="Center" />

                  <Border IsVisible="{Binding HasError}"
                          Background="{StaticResource GlucoDesk.Brush.DangerSoft}"
                          BorderBrush="{StaticResource GlucoDesk.Brush.Danger}"
                          BorderThickness="1"
                          CornerRadius="14"
                          Padding="14">
                    <TextBlock Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GlucoDesk.Brush.Danger}" />
                  </Border>
                </StackPanel>
              </Grid>

            </StackPanel>
          </Border>

        </StackPanel>
      </Grid>
    </ScrollViewer>
  </Border>
</UserControl>
