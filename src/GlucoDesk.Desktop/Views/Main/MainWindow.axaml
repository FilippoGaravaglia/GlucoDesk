<Window
    x:Class="GlucoDesk.Desktop.Views.Main.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:accountViews="clr-namespace:GlucoDesk.Desktop.Views.Account"
    xmlns:accountViewModels="clr-namespace:GlucoDesk.Desktop.ViewModels.Account"
    xmlns:dashboardViews="clr-namespace:GlucoDesk.Desktop.Views.Dashboard"
    xmlns:dashboardViewModels="clr-namespace:GlucoDesk.Desktop.ViewModels.Dashboard"
    xmlns:diaryViews="clr-namespace:GlucoDesk.Desktop.Views.Diary"
    xmlns:diaryViewModels="clr-namespace:GlucoDesk.Desktop.ViewModels.Diary"
    xmlns:settingsViews="clr-namespace:GlucoDesk.Desktop.Views.Settings"
    xmlns:settingsViewModels="clr-namespace:GlucoDesk.Desktop.ViewModels.Settings"
    Title="GlucoDesk"
    Width="1280"
    Height="820"
    MinWidth="1180"
    MinHeight="760"
    Background="{StaticResource GlucoDesk.Brush.AppBackground}">

  <Window.DataTemplates>
    <DataTemplate DataType="{x:Type dashboardViewModels:DashboardViewModel}">
      <dashboardViews:DashboardView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type diaryViewModels:DiaryViewModel}">
      <diaryViews:DiaryView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type accountViewModels:AccountViewModel}">
      <accountViews:AccountView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type settingsViewModels:SettingsViewModel}">
      <settingsViews:SettingsView />
    </DataTemplate>
  </Window.DataTemplates>

  <Grid ColumnDefinitions="280,*"
        Background="{StaticResource GlucoDesk.Brush.AppBackground}">

    <Border Grid.Column="0"
            Classes="app-sidebar"
            Padding="22">

      <Grid RowDefinitions="Auto,*,Auto">

        <StackPanel Grid.Row="0"
                    Spacing="24">

          <StackPanel Spacing="10">
            <Image Source="avares://GlucoDesk.Desktop/Assets/Brand/glucodesk-wordmark-removebg-preview.png"
                   Width="228"
                   Height="64"
                   Stretch="Uniform"
                   HorizontalAlignment="Left"
                   Margin="0,2,0,0" />

            <TextBlock Text="{DynamicResource SidebarSubtitle}"
                       Classes="sidebar-subtitle"
                       Margin="4,0,0,0" />
          </StackPanel>

          <StackPanel Spacing="10">
            <Button Content="{DynamicResource NavDashboard}"
                    Classes="nav-button"
                    Classes.accent="{Binding IsDashboardSelected}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Command="{Binding ShowDashboardCommand}" />

            <Button Content="{DynamicResource NavDiary}"
                    Classes="nav-button"
                    Classes.accent="{Binding IsDiarySelected}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Command="{Binding ShowDiaryCommand}" />

            <Button Content="{DynamicResource NavAccount}"
                    Classes="nav-button"
                    Classes.accent="{Binding IsAccountSelected}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Command="{Binding ShowAccountCommand}" />

            <Button Content="{DynamicResource NavSettings}"
                    Classes="nav-button"
                    Classes.accent="{Binding IsSettingsSelected}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Command="{Binding ShowSettingsCommand}" />
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Spacing="14"
                    VerticalAlignment="Bottom">

          <Border Padding="18"
                  CornerRadius="20"
                  BorderThickness="1"
                  BorderBrush="{StaticResource GlucoDesk.Brush.BorderSoft}"
                  Background="{StaticResource GlucoDesk.Brush.SurfaceSoft}">
            <StackPanel Spacing="8">

              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="12">
                <StackPanel Spacing="3">
                  <TextBlock Text="{DynamicResource SidebarLocalHistoryTitle}"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource GlucoDesk.Brush.TextPrimary}" />

                  <TextBlock Text="{Binding LocalHistoryStatusText}"
                             FontSize="13"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}"
                             TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Column="1"
                        Classes="badge"
                        VerticalAlignment="Top">
                  <TextBlock Text="{Binding LocalHistoryBadgeText}"
                             FontSize="12"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource GlucoDesk.Brush.TextSecondary}" />
                </Border>
              </Grid>

              <TextBlock Text="{Binding LocalHistoryDescriptionText}"
                         TextWrapping="Wrap"
                         Classes="sidebar-note" />

              <TextBlock Text="{Binding BackgroundSyncStatus.LastUpdateText}"
                         Classes="sync-status-meta"
                         IsVisible="{Binding BackgroundSyncStatus.HasSuccessfulSync}"
                         TextWrapping="Wrap" />

            </StackPanel>
          </Border>

          <Border Padding="18"
                  CornerRadius="20"
                  BorderThickness="1"
                  BorderBrush="{StaticResource GlucoDesk.Brush.BorderSoft}"
                  Background="{StaticResource GlucoDesk.Brush.AccentPale}">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="12">
              <Border Width="10"
                      Height="10"
                      CornerRadius="999"
                      Background="{StaticResource GlucoDesk.Brush.Accent}"
                      VerticalAlignment="Top"
                      Margin="0,5,0,0" />

              <StackPanel Grid.Column="1"
                          Spacing="6">
                <TextBlock Text="{DynamicResource SidebarPrivateByDesignTitle}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}" />

                <TextBlock Text="{DynamicResource SidebarPrivateByDesignDescription}"
                           TextWrapping="Wrap"
                           Classes="sidebar-note" />
              </StackPanel>
            </Grid>
          </Border>

          <Border Padding="18"
                  CornerRadius="20"
                  BorderThickness="1"
                  BorderBrush="{StaticResource GlucoDesk.Brush.BorderSoft}"
                  Background="{StaticResource GlucoDesk.Brush.IndigoSoft}">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="12">
              <Border Width="10"
                      Height="10"
                      CornerRadius="999"
                      Background="{StaticResource GlucoDesk.Brush.Indigo}"
                      VerticalAlignment="Top"
                      Margin="0,5,0,0" />

              <StackPanel Grid.Column="1"
                          Spacing="6">
                <TextBlock Text="{DynamicResource SidebarSafetyNoticeTitle}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource GlucoDesk.Brush.Indigo}" />

                <TextBlock Text="{DynamicResource SidebarSafetyNoticeDescription}"
                           TextWrapping="Wrap"
                           Classes="sidebar-note" />
              </StackPanel>
            </Grid>
          </Border>

        </StackPanel>
      </Grid>
    </Border>

    <ContentControl Grid.Column="1"
                    Content="{Binding CurrentContent}" />
  </Grid>
</Window>
