<Window
    x:Class="GlucoDesk.Desktop.Views.Main.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:accountViews="clr-namespace:GlucoDesk.Desktop.Views.Account"
    xmlns:accountViewModels="clr-namespace:GlucoDesk.Desktop.ViewModels.Account"
    xmlns:dashboardViews="clr-namespace:GlucoDesk.Desktop.Views.Dashboard"
    xmlns:dashboardViewModels="clr-namespace:GlucoDesk.Desktop.ViewModels.Dashboard"
    xmlns:settingsViews="clr-namespace:GlucoDesk.Desktop.Views.Settings"
    xmlns:settingsViewModels="clr-namespace:GlucoDesk.Desktop.ViewModels.Settings"
    Title="GlucoDesk"
    Width="1180"
    Height="760"
    MinWidth="920"
    MinHeight="620"
    Background="{StaticResource GlucoDesk.Brush.AppBackground}">

  <Window.DataTemplates>
    <DataTemplate DataType="{x:Type dashboardViewModels:DashboardViewModel}">
      <dashboardViews:DashboardView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type accountViewModels:AccountViewModel}">
      <accountViews:AccountView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type settingsViewModels:SettingsViewModel}">
      <settingsViews:SettingsView />
    </DataTemplate>
  </Window.DataTemplates>

  <Grid ColumnDefinitions="280,*"
        Background="{StaticResource GlucoDesk.Brush.AppBackground}">

    <Border Grid.Column="0"
            Classes="app-sidebar"
            Padding="22">
      <Grid RowDefinitions="Auto,*,Auto">

        <StackPanel Grid.Row="0"
                    Spacing="24">

          <StackPanel Spacing="10">
            <Image Source="avares://GlucoDesk.Desktop/Assets/Brand/glucodesk-wordmark-removebg-preview.png"
                   Width="228"
                   Height="64"
                   Stretch="Uniform"
                   HorizontalAlignment="Left"
                   Margin="0,2,0,0" />

            <TextBlock Text="Desktop companion"
                       Classes="sidebar-subtitle"
                       Margin="4,0,0,0" />
          </StackPanel>

          <StackPanel Spacing="10">
            <Button Content="Dashboard"
                    Classes="nav-button"
                    Classes.accent="{Binding IsDashboardSelected}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Command="{Binding ShowDashboardCommand}" />

            <Button Content="Account"
                    Classes="nav-button"
                    Classes.accent="{Binding IsAccountSelected}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Command="{Binding ShowAccountCommand}" />

            <Button Content="Settings"
                    Classes="nav-button"
                    Classes.accent="{Binding IsSettingsSelected}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Command="{Binding ShowSettingsCommand}" />
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Spacing="12">

          <Border Classes="sync-status-card">
            <StackPanel Spacing="6">
              <TextBlock Text="{Binding BackgroundSyncStatus.Title}"
                         Classes="sync-status-label" />

              <TextBlock Text="{Binding BackgroundSyncStatus.StatusText}"
                         Classes="sync-status-title" />

              <TextBlock Text="{Binding BackgroundSyncStatus.SummaryText}"
                         Classes="sync-status-summary"
                         TextWrapping="Wrap" />

              <TextBlock Text="{Binding BackgroundSyncStatus.SupportingText}"
                         Classes="sync-status-supporting"
                         TextWrapping="Wrap" />

              <TextBlock Text="{Binding BackgroundSyncStatus.LastUpdateText}"
                         Classes="sync-status-meta"
                         IsVisible="{Binding BackgroundSyncStatus.HasSuccessfulSync}" />
            </StackPanel>
          </Border>

          <Border Classes="sidebar-note-card">
            <StackPanel Spacing="8">
              <TextBlock Text="Companion mode"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}" />

              <TextBlock Text="Private, local-first desktop experience for glucose awareness."
                         TextWrapping="Wrap"
                         Classes="sidebar-note" />
            </StackPanel>
          </Border>

          <Border Classes="sidebar-note-card"
                  Background="{StaticResource GlucoDesk.Brush.IndigoSoft}">
            <StackPanel Spacing="8">
              <TextBlock Text="Safety notice"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource GlucoDesk.Brush.Indigo}" />

              <TextBlock Text="Not a medical device. Do not use for treatment decisions."
                         TextWrapping="Wrap"
                         Classes="sidebar-note" />
            </StackPanel>
          </Border>

        </StackPanel>
      </Grid>
    </Border>

    <ContentControl Grid.Column="1"
                    Content="{Binding CurrentContent}" />
  </Grid>
</Window>