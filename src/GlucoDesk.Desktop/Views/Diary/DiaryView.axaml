<UserControl
    x:Class="GlucoDesk.Desktop.Views.Diary.DiaryView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ScrollViewer>
    <Grid RowDefinitions="Auto,Auto,*"
          Margin="32"
          MaxWidth="920">

      <StackPanel Grid.Row="0"
                  Spacing="8"
                  Margin="0,0,0,24">
        <TextBlock Text="Glycemic diary"
                   FontSize="30"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource GlucoDesk.Brush.TextPrimary}" />

        <TextBlock Text="Export a clean daily diary from your local glucose history."
                   FontSize="15"
                   Foreground="{StaticResource GlucoDesk.Brush.TextSecondary}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <Border Grid.Row="1"
              Classes="dashboard-card"
              Padding="24"
              Margin="0,0,0,18">
        <StackPanel Spacing="20">

          <Grid ColumnDefinitions="*,*"
                ColumnSpacing="20">

            <StackPanel Grid.Column="0"
                        Spacing="6">
              <TextBlock Text="Period"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource GlucoDesk.Brush.TextPrimary}" />

              <ComboBox ItemsSource="{Binding PeriodPresets}"
                        SelectedItem="{Binding SelectedPeriodPreset}"
                        IsEnabled="{Binding CanEditSelection}"
                        MinWidth="280" />

              <TextBlock Text="{Binding SelectedPeriodPreset.Description}"
                         FontSize="12"
                         Foreground="{StaticResource GlucoDesk.Brush.TextSecondary}"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Spacing="6">
              <TextBlock Text="Format"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource GlucoDesk.Brush.TextPrimary}" />

              <ComboBox ItemsSource="{Binding Formats}"
                        SelectedItem="{Binding SelectedFormat}"
                        IsEnabled="{Binding CanEditSelection}"
                        MinWidth="280" />

              <TextBlock Text="{Binding SelectedFormat.Description}"
                         FontSize="12"
                         Foreground="{StaticResource GlucoDesk.Brush.TextSecondary}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Grid>

          <Border Padding="14"
                  CornerRadius="14"
                  Background="{StaticResource GlucoDesk.Brush.SurfaceSoft}">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="16">
              <StackPanel Grid.Column="0"
                          Spacing="6">
                <TextBlock Text="{Binding PreviewStatusTitle}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource GlucoDesk.Brush.TextPrimary}" />

                <TextBlock Text="{Binding PreviewStatusText}"
                           FontSize="13"
                           Foreground="{StaticResource GlucoDesk.Brush.TextSecondary}"
                           TextWrapping="Wrap" />

                <TextBlock Text="{Binding PreviewCoverageText}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}"
                           TextWrapping="Wrap" />

                <TextBlock Text="{Binding PreviewDetailsText}"
                           FontSize="12"
                           Foreground="{StaticResource GlucoDesk.Brush.TextMuted}"
                           TextWrapping="Wrap" />
              </StackPanel>

              <Button Grid.Column="1"
                      Content="{Binding RefreshPreviewButtonText}"
                      Command="{Binding RefreshPreviewCommand}"
                      IsEnabled="{Binding CanEditSelection}"
                      VerticalAlignment="Center" />
            </Grid>
          </Border>

          <Border Padding="14"
                  CornerRadius="14"
                  Background="{StaticResource GlucoDesk.Brush.SurfaceSoft}">
            <StackPanel Spacing="6">
              <TextBlock Text="{Binding StatusTitle}"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource GlucoDesk.Brush.TextPrimary}" />

              <TextBlock Text="{Binding StatusText}"
                         FontSize="13"
                         Foreground="{StaticResource GlucoDesk.Brush.TextSecondary}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <Button Content="{Binding ExportButtonText}"
                  Classes="primary-button"
                  Command="{Binding ExportCommand}"
                  HorizontalAlignment="Left"
                  IsEnabled="{Binding CanEditSelection}" />

        </StackPanel>
      </Border>

      <Border Grid.Row="2"
              Classes="dashboard-card"
              Padding="18">
        <StackPanel Spacing="8">
          <TextBlock Text="What is included"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource GlucoDesk.Brush.TextPrimary}" />

          <TextBlock Text="The diary contains daily summaries, breakfast/lunch/dinner/pre-night values, time-in-range, data coverage and incomplete-data indicators."
                     Foreground="{StaticResource GlucoDesk.Brush.TextSecondary}"
                     TextWrapping="Wrap" />

          <TextBlock Text="GlucoDesk is not a medical device. The exported diary is for personal awareness and must not be used for treatment decisions."
                     Foreground="{StaticResource GlucoDesk.Brush.TextMuted}"
                     FontSize="12"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>

    </Grid>
  </ScrollViewer>
</UserControl>