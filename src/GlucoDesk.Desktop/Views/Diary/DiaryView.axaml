<UserControl
    x:Class="GlucoDesk.Desktop.Views.Diary.DiaryView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border Classes="page-shell">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <Grid RowDefinitions="Auto,*"
            Margin="30"
            RowSpacing="26"
            MinWidth="860"
            MaxWidth="1680"
            HorizontalAlignment="Stretch">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="24">
          <StackPanel Spacing="8">
            <TextBlock Text="{DynamicResource DiaryPageTitle}"
                       Classes="page-title" />

            <TextBlock Text="{DynamicResource DiaryPageSubtitle}"
                       Classes="secondary"
                       FontSize="16"
                       TextWrapping="Wrap" />
          </StackPanel>

          <Border MinWidth="260" Grid.Column="1"
                  Classes="badge-accent"
                  VerticalAlignment="Top">
            <TextBlock Text="{DynamicResource DiaryLocalExportBadge}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}" />
          </Border>
        </Grid>

        <StackPanel Grid.Row="1"
                    Spacing="22">

          <Border Classes="surface-card"
                  Padding="26">
            <StackPanel Spacing="24">

              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="24">
                <StackPanel Spacing="4">
                  <TextBlock Text="{DynamicResource DiaryExportSetupTitle}"
                             Classes="section-title" />

                  <TextBlock Text="{DynamicResource DiaryExportSetupDescription}"
                             Classes="secondary"
                             FontSize="13"
                             TextWrapping="Wrap" />
                </StackPanel>

                <Button Grid.Column="1"
                        Content="{Binding RefreshPreviewButtonText}"
                        Command="{Binding RefreshPreviewCommand}"
                        IsEnabled="{Binding CanEditSelection}"
                        VerticalAlignment="Center" />
              </Grid>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="22">

                <StackPanel Grid.Column="0"
                            Spacing="8">
                  <TextBlock Text="{DynamicResource DiaryPeriod}"
                             Classes="metric-label" />

                  <ComboBox ItemsSource="{Binding PeriodPresets}"
                            SelectedItem="{Binding SelectedPeriodPreset}"
                            IsEnabled="{Binding CanEditSelection}"
                            HorizontalAlignment="Stretch" />

                  <TextBlock Text="{Binding SelectedPeriodPreset.Description}"
                             Classes="muted"
                             FontSize="12"
                             TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Spacing="8">
                  <TextBlock Text="{DynamicResource DiaryFormat}"
                             Classes="metric-label" />

                  <ComboBox ItemsSource="{Binding Formats}"
                            SelectedItem="{Binding SelectedFormat}"
                            IsEnabled="{Binding CanEditSelection}"
                            HorizontalAlignment="Stretch" />

                  <TextBlock Text="{Binding SelectedFormat.Description}"
                             Classes="muted"
                             FontSize="12"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Grid>

              <Border Height="1"
                      Background="{StaticResource GlucoDesk.Brush.BorderSoft}" />

              <Grid ColumnDefinitions="1.15*,0.85*"
                    ColumnSpacing="28">

                <StackPanel Grid.Column="0"
                            Spacing="8">
                  <TextBlock Text="{DynamicResource DiaryDataPreviewTitle}"
                             Classes="section-title" />

                  <TextBlock Text="{Binding PreviewStatusText}"
                             Classes="secondary"
                             FontSize="13"
                             TextWrapping="Wrap" />

                  <TextBlock Text="{Binding PreviewCoverageText}"
                             FontSize="13"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}"
                             TextWrapping="Wrap" />

                  <TextBlock Text="{Binding PreviewDetailsText}"
                             Classes="muted"
                             FontSize="12"
                             TextWrapping="Wrap" />
                </StackPanel>

                <Border MinWidth="260" Grid.Column="1"
                        Padding="20"
                        CornerRadius="18"
                        Background="{StaticResource GlucoDesk.Brush.SurfaceSoft}">
                  <StackPanel Spacing="12">
                    <TextBlock Text="{Binding StatusTitle}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GlucoDesk.Brush.TextPrimary}"
                               TextWrapping="Wrap" />

                    <TextBlock Text="{Binding StatusText}"
                               Classes="secondary"
                               FontSize="13"
                               TextWrapping="Wrap" />

                    <Button Content="{Binding ExportButtonText}"
                            Classes="primary-button"
                            Command="{Binding ExportCommand}"
                            HorizontalAlignment="Left"
                            IsEnabled="{Binding CanEditSelection}"
                            Margin="0,8,0,0" />
                  </StackPanel>
                </Border>
              </Grid>

            </StackPanel>
          </Border>

          <Grid ColumnDefinitions="1.1*,0.9*"
                ColumnSpacing="22">

            <Border Grid.Column="0"
                    Classes="surface-card"
                    Padding="24">
              <StackPanel Spacing="10">
                <TextBlock Text="{DynamicResource DiaryWhatIsIncludedTitle}"
                           Classes="section-title" />

                <TextBlock Text="{DynamicResource DiaryWhatIsIncludedDescription}"
                           Classes="secondary"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <Border MinWidth="260" Grid.Column="1"
                    Padding="24"
                    CornerRadius="22"
                    BorderThickness="1"
                    BorderBrush="{StaticResource GlucoDesk.Brush.BorderSoft}"
                    Background="{StaticResource GlucoDesk.Brush.AccentPale}">
              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="12">
                <Border Width="10"
                        Height="10"
                        CornerRadius="999"
                        Background="{StaticResource GlucoDesk.Brush.Indigo}"
                        VerticalAlignment="Top"
                        Margin="0,5,0,0" />

                <TextBlock Grid.Column="1"
                           Text="{DynamicResource DiarySafetyDisclaimer}"
                           Classes="secondary"
                           FontSize="13"
                           TextWrapping="Wrap" />
              </Grid>
            </Border>

          </Grid>

        </StackPanel>
      </Grid>
    </ScrollViewer>
  </Border>
</UserControl>
