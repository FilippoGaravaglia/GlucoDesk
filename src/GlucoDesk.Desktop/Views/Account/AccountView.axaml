<UserControl
    x:Class="GlucoDesk.Desktop.Views.Account.AccountView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border Classes="page-shell">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">

      <Grid RowDefinitions="Auto,Auto"
            Margin="30"
            RowSpacing="26"
            MinWidth="860"
            MaxWidth="1680"
            HorizontalAlignment="Stretch">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="24">

          <StackPanel Spacing="8">
            <TextBlock Text="{DynamicResource NavAccount}"
                       Classes="page-title" />

            <TextBlock Text="{DynamicResource AccountPageSubtitle}"
                       Classes="secondary"
                       FontSize="16"
                       TextWrapping="Wrap" />
          </StackPanel>

          <Border MinWidth="260" Grid.Column="1"
                  Classes="badge-accent"
                  VerticalAlignment="Top">

            <TextBlock Text="{Binding CredentialStorageStatusText}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}" />
          </Border>
        </Grid>

        <Border Grid.Row="1"
                Classes="surface-card"
                Padding="24"
                VerticalAlignment="Top">

          <Grid ColumnDefinitions="1.08*,0.92*"
                ColumnSpacing="34">

            <StackPanel Grid.Column="0"
                        Spacing="22">

              <StackPanel Spacing="4">
                <TextBlock Text="{DynamicResource AccountDexcomShareTitle}"
                           Classes="section-title" />

                <TextBlock Text="{DynamicResource AccountDexcomShareDescription}"
                           Classes="secondary"
                           FontSize="13"
                           TextWrapping="Wrap" />
              </StackPanel>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="18">

                <Border Grid.Column="0"
                        Padding="16"
                        CornerRadius="18"
                        BorderThickness="1"
                        BorderBrush="{StaticResource GlucoDesk.Brush.BorderSoft}"
                        Background="{StaticResource GlucoDesk.Brush.SurfaceSoft}">

                  <StackPanel Spacing="7">
                    <TextBlock Text="{DynamicResource AccountCredentialStorageTitle}"
                               Classes="metric-label" />

                    <TextBlock Text="{Binding CredentialStorageStatusText}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}"
                               TextWrapping="Wrap" />

                    <TextBlock Text="{Binding CredentialStorageDescriptionText}"
                               Classes="muted"
                               FontSize="12"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Border MinWidth="260" Grid.Column="1"
                        Padding="16"
                        CornerRadius="18"
                        BorderThickness="1"
                        BorderBrush="{StaticResource GlucoDesk.Brush.BorderSoft}"
                        Background="{StaticResource GlucoDesk.Brush.SurfaceSoft}">

                  <StackPanel Spacing="7">
                    <TextBlock Text="{DynamicResource AccountConnectionDiagnosticsTitle}"
                               Classes="metric-label" />

                    <TextBlock Text="{Binding ConnectionDiagnosticStatusText}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}"
                               TextWrapping="Wrap" />

                    <TextBlock Text="{Binding ConnectionDiagnosticDescriptionText}"
                               Classes="muted"
                               FontSize="12"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </Grid>

              <Border Height="1"
                      Background="{StaticResource GlucoDesk.Brush.BorderSoft}" />

              <Grid RowDefinitions="Auto,Auto,Auto"
                    RowSpacing="18">

                <StackPanel Grid.Row="0"
                            Spacing="8">
                  <TextBlock Text="{DynamicResource AccountRegionLabel}"
                             Classes="metric-label" />

                  <ComboBox ItemsSource="{Binding RegionOptions}"
                            SelectedItem="{Binding SelectedRegion}"
                            HorizontalAlignment="Stretch" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Spacing="8">
                  <TextBlock Text="{DynamicResource AccountDexcomEmailLabel}"
                             Classes="metric-label" />

                  <TextBox Text="{Binding EmailText}"
                           PlaceholderText="name@example.com"
                           HorizontalAlignment="Stretch" />
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Spacing="8">
                  <TextBlock Text="{DynamicResource AccountDexcomPasswordLabel}"
                             Classes="metric-label" />

                  <TextBox Text="{Binding PasswordText}"
                           PasswordChar="•"
                           PlaceholderText="{DynamicResource AccountPasswordPlaceholder}"
                           HorizontalAlignment="Stretch" />

                  <TextBlock Text="{Binding PasswordHelpText}"
                             Classes="muted"
                             FontSize="12"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Grid>

              <Border Height="1"
                      Background="{StaticResource GlucoDesk.Brush.BorderSoft}" />

              <Grid RowDefinitions="Auto,Auto,Auto"
                    RowSpacing="14">

                <WrapPanel Grid.Row="0"
                           Orientation="Horizontal">
                  <Button Content="{DynamicResource AccountSaveButton}"
                          Command="{Binding SaveCommand}"
                          Margin="0,0,10,10" />

                  <Button Content="{DynamicResource AccountTestConnectionButton}"
                          Command="{Binding TestConnectionCommand}"
                          Margin="0,0,10,10" />

                  <Button Content="{DynamicResource AccountLoadSavedButton}"
                          Command="{Binding LoadCommand}"
                          Classes="segment-button"
                          Margin="0,0,10,10" />

                  <Button Content="{DynamicResource AccountClearButton}"
                          Command="{Binding ClearCredentialsCommand}"
                          Background="{StaticResource GlucoDesk.Brush.DangerPale}"
                          Foreground="{StaticResource GlucoDesk.Brush.Danger}"
                          BorderBrush="#FCA5A5"
                          Margin="0,0,10,10" />
                </WrapPanel>

                <TextBlock Grid.Row="1"
                           Text="{Binding StatusMessage}"
                           Classes="secondary"
                           TextWrapping="Wrap" />

                <Border Grid.Row="2"
                        IsVisible="{Binding HasError}"
                        Background="{StaticResource GlucoDesk.Brush.DangerSoft}"
                        BorderBrush="{StaticResource GlucoDesk.Brush.Danger}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14">

                  <TextBlock Text="{Binding ErrorMessage}"
                             TextWrapping="Wrap"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource GlucoDesk.Brush.Danger}" />
                </Border>
              </Grid>

            </StackPanel>

            <Border MinWidth="260" Grid.Column="1"
                    BorderThickness="1,0,0,0"
                    BorderBrush="{StaticResource GlucoDesk.Brush.BorderSoft}"
                    Padding="28,0,0,0">

              <StackPanel Spacing="20">

                <StackPanel Spacing="4">
                  <TextBlock Text="{DynamicResource AccountHowItWorksTitle}"
                             Classes="section-title" />

                  <TextBlock Text="{DynamicResource AccountHowItWorksDescription}"
                             Classes="secondary"
                             FontSize="13"
                             TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Spacing="16">

                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="12">
                    <Border Width="10"
                            Height="10"
                            CornerRadius="999"
                            Background="{StaticResource GlucoDesk.Brush.Accent}"
                            VerticalAlignment="Top"
                            Margin="0,5,0,0" />

                    <StackPanel Grid.Column="1"
                                Spacing="4">
                      <TextBlock Text="{DynamicResource AccountAutomaticReconnectTitle}"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource GlucoDesk.Brush.AccentStrong}" />

                      <TextBlock Text="{DynamicResource AccountAutomaticReconnectDescription}"
                                 TextWrapping="Wrap"
                                 Classes="secondary"
                                 FontSize="13" />
                    </StackPanel>
                  </Grid>

                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="12">
                    <Border Width="10"
                            Height="10"
                            CornerRadius="999"
                            Background="{StaticResource GlucoDesk.Brush.Indigo}"
                            VerticalAlignment="Top"
                            Margin="0,5,0,0" />

                    <StackPanel Grid.Column="1"
                                Spacing="4">
                      <TextBlock Text="{DynamicResource AccountConnectionTestTitle}"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource GlucoDesk.Brush.Indigo}" />

                      <TextBlock Text="{DynamicResource AccountConnectionTestDescription}"
                                 TextWrapping="Wrap"
                                 Classes="secondary"
                                 FontSize="13" />
                    </StackPanel>
                  </Grid>

                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="12">
                    <Border Width="10"
                            Height="10"
                            CornerRadius="999"
                            Background="{StaticResource GlucoDesk.Brush.Indigo}"
                            VerticalAlignment="Top"
                            Margin="0,5,0,0" />

                    <StackPanel Grid.Column="1"
                                Spacing="4">
                      <TextBlock Text="{DynamicResource AccountPrivacyTitle}"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource GlucoDesk.Brush.Indigo}" />

                      <TextBlock Text="{DynamicResource AccountPrivacyDescription}"
                                 TextWrapping="Wrap"
                                 Classes="secondary"
                                 FontSize="13" />
                    </StackPanel>
                  </Grid>

                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="12">
                    <Border Width="10"
                            Height="10"
                            CornerRadius="999"
                            Background="{StaticResource GlucoDesk.Brush.Warning}"
                            VerticalAlignment="Top"
                            Margin="0,5,0,0" />

                    <StackPanel Grid.Column="1"
                                Spacing="4">
                      <TextBlock Text="{DynamicResource SidebarSafetyNoticeTitle}"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource GlucoDesk.Brush.Warning}" />

                      <TextBlock Text="{DynamicResource AccountSafetyDescription}"
                                 TextWrapping="Wrap"
                                 Classes="secondary"
                                 FontSize="13" />
                    </StackPanel>
                  </Grid>

                </StackPanel>
              </StackPanel>
            </Border>

          </Grid>
        </Border>
      </Grid>
    </ScrollViewer>
  </Border>
</UserControl>
