<Application
    x:Class="GlucoDesk.Desktop.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Name="GlucoDesk"
    RequestedThemeVariant="Light">

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://GlucoDesk.Desktop/Styles/GlucoDeskTheme.axaml" />
  </Application.Styles>
</Application>
